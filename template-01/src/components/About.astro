---
import { content } from '../content';

const { about } = content.sections;
---

{about.enabled && (
  <section class="about">
    <div class="about-inner">
      {about.image && (
        <img src={about.image} alt={about.image_alt ?? ''} class="about-img" />
      )}
      <div class="about-text">
        <h2>{about.title}</h2>
        <p>{about.text}</p>
      </div>
    </div>
  </section>
)}

<style>
  .about {
    padding: 5rem 2rem;
    background: var(--color-bg);
    color: var(--color-text);
  }
  .about-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    gap: 3rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .about-img {
    width: 100%;
    max-width: 380px;
    border-radius: 8px;
    object-fit: cover;
  }
  .about-text { flex: 1; min-width: 260px; }
  h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }
  p { font-family: var(--font-body); line-height: 1.7; opacity: 0.9; }
</style>
