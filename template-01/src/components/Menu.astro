---
import { content } from '../content';

const { menu } = content.sections;

const ALLERGENI: Record<number, string> = {
  1: 'Glutine', 2: 'Crostacei', 3: 'Uova', 4: 'Pesce',
  5: 'Arachidi', 6: 'Soia', 7: 'Latte', 8: 'Frutta a guscio',
  9: 'Sedano', 10: 'Senape', 11: 'Sesamo', 12: 'Anidride solforosa',
  13: 'Lupini', 14: 'Molluschi'
};
---

<section class="menu">
  <h2>Menù</h2>
  {menu.categories.map(cat => (
    <div class="category">
      <h3 class="cat-title">{cat.name}</h3>
      <ul class="items">
        {cat.items.map(item => (
          <li class="item">
            {item.image && (
              <img src={item.image} alt={item.image_alt ?? item.name} class="item-img" />
            )}
            <div class="item-info">
              <div class="item-header">
                <span class="item-name">{item.name}</span>
                {item.badge && <span class="badge">{item.badge}</span>}
                <span class="item-price">€ {item.price}</span>
              </div>
              <p class="item-desc">{item.description}</p>
              {item.allergeni && item.allergeni.length > 0 && (
                <p class="allergeni">
                  Allergeni: {item.allergeni.map(id => ALLERGENI[id] ?? id).join(', ')}
                </p>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>
  ))}
</section>

<style>
  .menu {
    padding: 5rem 2rem;
    background: var(--color-bg);
    color: var(--color-text);
  }
  h2 {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--color-primary);
  }
  .category { max-width: 800px; margin: 0 auto 3rem; }
  .cat-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    border-bottom: 2px solid var(--color-primary);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .items { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1.25rem; }
  .item { display: flex; gap: 1rem; align-items: flex-start; }
  .item-img { width: 80px; height: 80px; object-fit: cover; border-radius: 6px; flex-shrink: 0; }
  .item-info { flex: 1; }
  .item-header { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.25rem; }
  .item-name { font-family: var(--font-body); font-weight: 600; }
  .item-price { margin-left: auto; font-weight: 700; color: var(--color-primary); }
  .badge {
    background: var(--color-primary); color: #fff;
    font-size: 0.7rem; padding: 0.1rem 0.5rem; border-radius: 20px; font-weight: 600;
  }
  .item-desc { font-family: var(--font-body); font-size: 0.9rem; opacity: 0.8; margin: 0; }
  .allergeni { font-size: 0.75rem; opacity: 0.6; margin: 0.25rem 0 0; font-style: italic; }
</style>
