---
import type { ClientContent } from "../../schema/content.schema";

interface Props {
	sections: ClientContent["sections"];
}
const { gallery } = Astro.props.sections;
---

{
	gallery.gallery_enabled && (
		<section class="gallery">
			<h2>{gallery.gallery_title}</h2>
			<div class="grid">
				{gallery.images.map((img: any) => (
					<img src={img} alt="Foto piatto" loading="lazy" />
				))}
			</div>
		</section>
	)
}
