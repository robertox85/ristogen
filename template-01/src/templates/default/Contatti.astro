---
import type { ClientContent } from "../../schema/content.schema";

interface Props {
	sections: ClientContent["sections"];
}
const { contatti } = Astro.props.sections;
---

<section class="contatti" id="contatti">
	<h2>{contatti.title}</h2>
	<div class="info">
		{
			contatti.address && (
				<p>
					<strong>📍 Indirizzo:</strong> {contatti.address}
				</p>
			)
		}
		{
			contatti.phone && (
				<p>
					<strong>📞 Telefono:</strong>{" "}
					<a href={`tel:${contatti.phone}`}>{contatti.phone}</a>
				</p>
			)
		}
		{
			contatti.email && (
				<p>
					<strong>✉️ Email:</strong>{" "}
					<a href={`mailto:${contatti.email}`}>{contatti.email}</a>
				</p>
			)
		}
		{
			contatti.hours && (
				<p>
					<strong>🕐 Orari:</strong> {contatti.hours}
				</p>
			)
		}
	</div>
	{
		contatti.googleMapsEmbed && (
			<div class="mt-4">
				<iframe
					src={contatti.googleMapsEmbed}
					width="100%"
					height="200"
					style="border:0;"
					allowfullscreen=""
					loading="lazy"
				/>
			</div>
		)
	}
</section>
