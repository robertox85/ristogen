---
import type { ClientContent } from "../../schema/content.schema";

interface Props {
	sections: ClientContent["sections"];
}
const { contatti } = Astro.props.sections;
---

<section class="contatti" id="contatti">
	<h2 data-editable="contatti_title">{contatti.contatti_title}</h2>
	<div class="info">
		{
			contatti.contatti_address && (
				<p data-editable="contatti_address">
					<strong>📍 Indirizzo:</strong> {contatti.contatti_address}
				</p>
			)
		}
		{
			contatti.contatti_phone && (
				<p>
					<strong>📞 Telefono:</strong>{" "}
					<a
						href={`tel:${contatti.contatti_phone}`}
						data-editable="contatti_phone"
					>
						{contatti.contatti_phone}
					</a>
				</p>
			)
		}
		{
			contatti.contatti_email && (
				<p>
					<strong>✉️ Email:</strong>{" "}
					<a
						href={`mailto:${contatti.contatti_email}`}
						data-editable="contatti_email"
					>
						{contatti.contatti_email}
					</a>
				</p>
			)
		}
		{
			contatti.contatti_hours && (
				<p data-editable="contatti_hours">
					<strong>🕐 Orari:</strong> {contatti.contatti_hours}
				</p>
			)
		}
	</div>
	{
		contatti.contatti_googleMapsEmbed && (
			<div class="mt-4">
				<iframe
					src={contatti.contatti_googleMapsEmbed}
					width="100%"
					height="200"
					style="border:0;"
					allowfullscreen=""
					loading="lazy"
				/>
			</div>
		)
	}
</section>
