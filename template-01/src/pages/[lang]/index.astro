---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/About.astro';
import Menu from '../../components/Menu.astro';
import Gallery from '../../components/Gallery.astro';
import Contatti from '../../components/Contatti.astro';
import { getContent, getAvailableLangs } from '../../content';

export function getStaticPaths() {
  return getAvailableLangs().map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: string };
const content = getContent(lang);
---

<Base {content}>
  <Hero sections={content.sections} />
  <About sections={content.sections} />
  <Menu sections={content.sections} lang={lang} />
  <Gallery sections={content.sections} />
  <Contatti sections={content.sections} />
</Base>
