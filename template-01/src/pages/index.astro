---
import Base from "../layouts/Base.astro";
import { getContent, getDefaultLang } from "../content";
import { resolveTemplate } from "../lib/resolveTemplate";

const restaurantData = getContent(getDefaultLang());

const templateFiles = import.meta.glob("../templates/*/index.astro", {
	eager: true,
}) as Record<string, { default: any }>;

const selectedTemplateName =
	restaurantData.sections?.template || __DEFAULT_TEMPLATE__;

// Una riga invece di ~10
const TemplateComponent = resolveTemplate(templateFiles, selectedTemplateName);
---

<Base content={restaurantData}>
	<TemplateComponent sections={restaurantData.sections} />
</Base>
