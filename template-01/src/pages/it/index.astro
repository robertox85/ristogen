---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Menu from '../../components/Menu.astro';
import { getContent } from '../../content';

const lang = 'it';
const content = await getContent(lang);
const { site } = content;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': site.schema_org.type,
  '@id': `${site.schema_org.url}/#restaurant`,
  'name': site.schema_org.name,
  'description': site.schema_org.description,
  'url': site.schema_org.url,
  'logo': site.schema_org.logo,
  'image': site.schema_org.image,
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': site.schema_org.address.streetAddress,
    'addressLocality': site.schema_org.address.addressLocality,
    'postalCode': site.schema_org.address.postalCode,
    'addressRegion': site.schema_org.address.addressRegion,
    'addressCountry': site.schema_org.address.addressCountry
  },
  'geo': {
    '@type': 'GeoCoordinates',
    'latitude': site.schema_org.latitude,
    'longitude': site.schema_org.longitude
  },
  'telephone': site.schema_org.telephone,
  'email': site.schema_org.email,
  'servesCuisine': site.schema_org.servesCuisine,
  'priceRange': site.schema_org.priceRange,
  'openingHoursSpecification': site.schema_org.openingHours.map(h => ({
    '@type': 'OpeningHoursSpecification',
    'dayOfWeek': h.dayOfWeek,
    'opens': h.opens,
    'closes': h.closes
  })),
  'hasMenu': { '@id': `${site.schema_org.url}/it/menu` }
});
---

<Base content={content}>
  <script type="application/ld+json" is:inline slot="head" set:html={jsonLd}></script>
  <Hero hero={content.hero} />
  <Menu categories={content.menu} lang={lang} />
</Base>
