---
export const prerender = false;
import { Astro } from "astro";
import { getContent } from "../../content";

const session = Astro.cookies.get("admin_session");
if (session?.value !== "authenticated") {
	return Astro.redirect("/admin/login");
}

const content = getContent("it");
---

<html lang="it">
	<head>
		<title>Dashboard Admin | Ristogen</title>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<script is:inline src="https://cdn.tailwindcss.com"></script>
		<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"
		></script>
		<link
			href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-gray-950 text-gray-100">
		<div class="flex h-screen">
			<aside
				class="w-64 bg-white border-r border-gray-200 p-6 flex flex-col gap-4 shadow-sm"
			>
				<h2 class="text-xl font-bold mb-6 text-gray-900">
					Ristogen Admin
				</h2>
				<nav class="flex flex-col gap-2">
					<button
						class="tab-btn text-left px-3 py-2 rounded-md font-semibold text-[15px] text-gray-700 hover:bg-indigo-50 focus:bg-indigo-100 focus:outline-none"
						data-tab="theme">Theme</button
					>
					<button
						class="tab-btn text-left px-3 py-2 rounded-md font-semibold text-[15px] text-gray-700 hover:bg-indigo-50 focus:bg-indigo-100 focus:outline-none"
						data-tab="hero">Hero</button
					>
					<button
						class="tab-btn text-left px-3 py-2 rounded-md font-semibold text-[15px] text-gray-700 hover:bg-indigo-50 focus:bg-indigo-100 focus:outline-none"
						data-tab="about">About</button
					>
					<button
						class="tab-btn text-left px-3 py-2 rounded-md font-semibold text-[15px] text-gray-700 hover:bg-indigo-50 focus:bg-indigo-100 focus:outline-none"
						data-tab="gallery">Gallery</button
					>
					<button
						class="tab-btn text-left px-3 py-2 rounded-md font-semibold text-[15px] text-gray-700 hover:bg-indigo-50 focus:bg-indigo-100 focus:outline-none"
						data-tab="menu">Menu</button
					>
					<button
						class="tab-btn text-left px-3 py-2 rounded-md font-semibold text-[15px] text-gray-700 hover:bg-indigo-50 focus:bg-indigo-100 focus:outline-none"
						data-tab="contatti">Contatti</button
					>
					<button
						class="tab-btn text-left px-3 py-2 rounded-md font-semibold text-[15px] text-gray-700 hover:bg-indigo-50 focus:bg-indigo-100 focus:outline-none"
						data-tab="footer">Footer</button
					>
				</nav>
			</aside>
			<main class="flex-1 p-10 overflow-y-auto bg-gray-50">
				<div class="max-w-3xl mx-auto flex flex-col gap-8">
					<section id="theme" class="tab-section">
						<div
							class="rounded-xl border border-gray-200 bg-white shadow-sm p-7"
						>
							<h3 class="text-lg font-bold mb-6 text-gray-900">
								Theme
							</h3>
							<form id="form-theme" class="space-y-8">
								<!-- ── COLORI BRAND ─────────────────────────────── -->
								<div>
									<p
										class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4"
									>
										Colori Brand
									</p>
									<div class="grid grid-cols-2 gap-6">
										<div class="flex items-center gap-3">
											<input
												type="color"
												name="theme_primary"
												value={content.theme.primary}
												class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
											/>
											<div>
												<p
													class="text-sm font-medium text-gray-700"
												>
													Colore Primario
												</p>
												<p
													class="text-xs text-gray-400"
												>
													Pulsanti, accenti
												</p>
											</div>
										</div>
										<div class="flex items-center gap-3">
											<input
												type="color"
												name="theme_secondary"
												value={content.theme.secondary}
												class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
											/>
											<div>
												<p
													class="text-sm font-medium text-gray-700"
												>
													Colore Secondario
												</p>
												<p
													class="text-xs text-gray-400"
												>
													Elementi decorativi
												</p>
											</div>
										</div>
										<div class="flex items-center gap-3">
											<input
												type="color"
												name="theme_bg"
												value={content.theme.bg}
												class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
											/>
											<div>
												<p
													class="text-sm font-medium text-gray-700"
												>
													Sfondo
												</p>
												<p
													class="text-xs text-gray-400"
												>
													Colore di fondo pagina
												</p>
											</div>
										</div>
										<div class="flex items-center gap-3">
											<input
												type="color"
												name="theme_text"
												value={content.theme.text}
												class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
											/>
											<div>
												<p
													class="text-sm font-medium text-gray-700"
												>
													Testo
												</p>
												<p
													class="text-xs text-gray-400"
												>
													Colore testo principale
												</p>
											</div>
										</div>
									</div>
								</div>

								<!-- ── TIPOGRAFIA ────────────────────────────────── -->
								<div>
									<p
										class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4"
									>
										Tipografia
									</p>
									<div class="grid grid-cols-2 gap-6">
										<!-- Font Heading card -->
										<div
											class="rounded-lg border border-gray-200 bg-gray-50 p-4"
										>
											<p
												class="text-sm font-semibold text-gray-700 mb-3"
											>
												Font Titoli
											</p>
											<div class="flex gap-4 mb-3">
												<label
													class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
												>
													<input
														type="radio"
														name="font_heading_mode"
														value="standard"
														checked={!content.theme
															.customFonts
															?.heading}
													/>
													Standard
												</label>
												<label
													class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
												>
													<input
														type="radio"
														name="font_heading_mode"
														value="custom"
														checked={!!content.theme
															.customFonts
															?.heading}
													/>
													Custom
												</label>
											</div>
											<div id="heading-standard-panel">
												<select
													name="theme_fontHeading"
													id="select-fontHeading"
													class="w-full px-3 py-2 rounded-md border border-gray-200 bg-white text-gray-900 text-sm"
												>
													<option
														value="'Playfair Display', serif"
														selected={content.theme
															.fontHeading ===
															"'Playfair Display', serif"}
														>Playfair Display</option
													>
													<option
														value="'Montserrat', sans-serif"
														selected={content.theme
															.fontHeading ===
															"'Montserrat', sans-serif"}
														>Montserrat</option
													>
													<option
														value="'Cormorant Garamond', serif"
														selected={content.theme
															.fontHeading ===
															"'Cormorant Garamond', serif"}
														>Cormorant Garamond</option
													>
													<option
														value="'Inter', sans-serif"
														selected={content.theme
															.fontHeading ===
															"'Inter', sans-serif"}
														>Inter</option
													>
													<option
														value="'Lora', serif"
														selected={content.theme
															.fontHeading ===
															"'Lora', serif"}
														>Lora</option
													>
													<option
														value="'Oswald', sans-serif"
														selected={content.theme
															.fontHeading ===
															"'Oswald', sans-serif"}
														>Oswald</option
													>
												</select>
											</div>
											<div
												id="heading-custom-panel"
												class="hidden"
											>
												<input
													type="file"
													name="font_heading_file"
													accept=".ttf,.woff2"
													class="w-full text-sm text-gray-900"
												/>
												{
													content.theme.customFonts
														?.heading && (
														<p class="text-xs text-green-600 mt-1">
															Caricato:{" "}
															{
																content.theme
																	.customFonts
																	.heading
															}
															{content.theme
																.customFonts
																.headingType && (
																<span class="ml-1 px-1.5 py-0.5 rounded bg-green-100 text-green-700 font-mono">
																	{
																		content
																			.theme
																			.customFonts
																			.headingType
																	}
																</span>
															)}
														</p>
													)
												}
											</div>
											<!-- Peso -->
											<div class="mt-4">
												<p
													class="text-xs text-gray-500 mb-1"
												>
													Peso carattere titoli
												</p>
												<div class="flex gap-2">
													{
														[
															["300", "Sottile"],
															["400", "Regolare"],
															[
																"700",
																"Grassetto",
															],
															[
																"900",
																"Extra Grassetto",
															],
														].map(
															([val, label]) => (
																<label class="flex-1 text-center cursor-pointer">
																	<input
																		type="radio"
																		name="theme_fontWeightHeading"
																		value={
																			val
																		}
																		checked={
																			content
																				.theme
																				.fontWeightHeading ===
																				val ||
																			(!content
																				.theme
																				.fontWeightHeading &&
																				val ===
																					"700")
																		}
																		class="sr-only peer"
																	/>
																	<span class="block py-1.5 px-1 rounded-md border border-gray-200 text-xs text-gray-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 transition">
																		{label}
																	</span>
																</label>
															),
														)
													}
												</div>
											</div>
											<!-- Interlinea -->
											<div class="mt-4">
												<div
													class="flex justify-between items-center mb-1"
												>
													<p
														class="text-xs text-gray-500"
													>
														Interlinea titoli
													</p>
													<span
														id="lh-heading-val"
														class="text-xs font-mono text-indigo-600"
														>{
															content.theme
																.lineHeightHeading ??
																"1.2"
														}</span
													>
												</div>
												<input
													type="range"
													name="theme_lineHeightHeading"
													min="1"
													max="2"
													step="0.1"
													value={content.theme
														.lineHeightHeading ??
														"1.2"}
													class="w-full accent-indigo-500"
													id="lh-heading-range"
												/>
											</div>
										</div>

										<!-- Font Body card -->
										<div
											class="rounded-lg border border-gray-200 bg-gray-50 p-4"
										>
											<p
												class="text-sm font-semibold text-gray-700 mb-3"
											>
												Font Testo
											</p>
											<div class="flex gap-4 mb-3">
												<label
													class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
												>
													<input
														type="radio"
														name="font_body_mode"
														value="standard"
														checked={!content.theme
															.customFonts?.body}
													/>
													Standard
												</label>
												<label
													class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
												>
													<input
														type="radio"
														name="font_body_mode"
														value="custom"
														checked={!!content.theme
															.customFonts?.body}
													/>
													Custom
												</label>
											</div>
											<div id="body-standard-panel">
												<select
													name="theme_fontBody"
													id="select-fontBody"
													class="w-full px-3 py-2 rounded-md border border-gray-200 bg-white text-gray-900 text-sm"
												>
													<option
														value="'Playfair Display', serif"
														selected={content.theme
															.fontBody ===
															"'Playfair Display', serif"}
														>Playfair Display</option
													>
													<option
														value="'Montserrat', sans-serif"
														selected={content.theme
															.fontBody ===
															"'Montserrat', sans-serif"}
														>Montserrat</option
													>
													<option
														value="'Cormorant Garamond', serif"
														selected={content.theme
															.fontBody ===
															"'Cormorant Garamond', serif"}
														>Cormorant Garamond</option
													>
													<option
														value="'Inter', sans-serif"
														selected={content.theme
															.fontBody ===
															"'Inter', sans-serif"}
														>Inter</option
													>
													<option
														value="'Lora', serif"
														selected={content.theme
															.fontBody ===
															"'Lora', serif"}
														>Lora</option
													>
													<option
														value="'Oswald', sans-serif"
														selected={content.theme
															.fontBody ===
															"'Oswald', sans-serif"}
														>Oswald</option
													>
												</select>
											</div>
											<div
												id="body-custom-panel"
												class="hidden"
											>
												<input
													type="file"
													name="font_body_file"
													accept=".ttf,.woff2"
													class="w-full text-sm text-gray-900"
												/>
												{
													content.theme.customFonts
														?.body && (
														<p class="text-xs text-green-600 mt-1">
															Caricato:{" "}
															{
																content.theme
																	.customFonts
																	.body
															}
															{content.theme
																.customFonts
																.bodyType && (
																<span class="ml-1 px-1.5 py-0.5 rounded bg-green-100 text-green-700 font-mono">
																	{
																		content
																			.theme
																			.customFonts
																			.bodyType
																	}
																</span>
															)}
														</p>
													)
												}
											</div>
											<!-- Peso -->
											<div class="mt-4">
												<p
													class="text-xs text-gray-500 mb-1"
												>
													Peso carattere testo
												</p>
												<div class="flex gap-2">
													{
														[
															["300", "Sottile"],
															["400", "Regolare"],
															[
																"700",
																"Grassetto",
															],
															[
																"900",
																"Extra Grassetto",
															],
														].map(
															([val, label]) => (
																<label class="flex-1 text-center cursor-pointer">
																	<input
																		type="radio"
																		name="theme_fontWeightBody"
																		value={
																			val
																		}
																		checked={
																			content
																				.theme
																				.fontWeightBody ===
																				val ||
																			(!content
																				.theme
																				.fontWeightBody &&
																				val ===
																					"400")
																		}
																		class="sr-only peer"
																	/>
																	<span class="block py-1.5 px-1 rounded-md border border-gray-200 text-xs text-gray-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 transition">
																		{label}
																	</span>
																</label>
															),
														)
													}
												</div>
											</div>
											<!-- Interlinea -->
											<div class="mt-4">
												<div
													class="flex justify-between items-center mb-1"
												>
													<p
														class="text-xs text-gray-500"
													>
														Interlinea testo
													</p>
													<span
														id="lh-body-val"
														class="text-xs font-mono text-indigo-600"
														>{
															content.theme
																.lineHeightBody ??
																"1.6"
														}</span
													>
												</div>
												<input
													type="range"
													name="theme_lineHeightBody"
													min="1"
													max="2.5"
													step="0.1"
													value={content.theme
														.lineHeightBody ??
														"1.6"}
													class="w-full accent-indigo-500"
													id="lh-body-range"
												/>
											</div>
										</div>
									</div>

									<!-- Dimensione base font -->
									<div class="mt-4">
										<div
											class="flex justify-between items-center mb-1"
										>
											<p
												class="text-sm font-medium text-gray-700"
											>
												Dimensione testo base
											</p>
											<span
												id="fs-base-val"
												class="text-xs font-mono text-indigo-600"
												>{
													content.theme
														.fontSizeBase ?? "1rem"
												}</span
											>
										</div>
										<input
											type="range"
											id="fs-base-range"
											name="theme_fontSizeBase_px"
											min="14"
											max="22"
											step="1"
											value={parseInt(
												(
													content.theme
														.fontSizeBase ?? "16px"
												).replace(/[^0-9]/g, ""),
											) || 16}
											class="w-full accent-indigo-500"
										/>
										<input
											type="hidden"
											name="theme_fontSizeBase"
											id="fs-base-hidden"
											value={content.theme.fontSizeBase ??
												"1rem"}
										/>
										<div
											class="flex justify-between text-xs text-gray-400 mt-1"
										>
											<span>Piccolo (14px)</span><span
												>Grande (22px)</span>
										</div>
									</div>

									<!-- Allineamento testo -->
									<div class="mt-4">
										<p
											class="text-sm font-medium text-gray-700 mb-2"
										>
											Allineamento testo
										</p>
										<div class="flex gap-2">
											{
												[
													["left", "← Sinistra"],
													["center", "⊜ Centro"],
													["right", "Destra →"],
												].map(([val, label]) => (
													<label class="flex-1 text-center cursor-pointer">
														<input
															type="radio"
															name="theme_textAlign"
															value={val}
															checked={
																content.theme
																	.textAlign ===
																	val ||
																(!content.theme
																	.textAlign &&
																	val ===
																		"left")
															}
															class="sr-only peer"
														/>
														<span class="block py-2 rounded-md border border-gray-200 text-sm text-gray-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 transition">
															{label}
														</span>
													</label>
												))
											}
										</div>
									</div>
								</div>

								<!-- ── GERARCHIA TITOLI ───────────────────────── -->
								<div>
									<p
										class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4"
									>
										Gerarchia Titoli
									</p>
									<div class="space-y-4">
										<!-- H1 Impatto Hero -->
										<div
											class="rounded-lg border border-gray-200 bg-gray-50 p-4"
										>
											<p
												class="text-sm font-semibold text-gray-700"
											>
												H1 — Impatto Hero
											</p>
											<p
												class="text-xs text-gray-400 mb-3"
											>
												Titolo principale della sezione
												hero
											</p>
											<div class="grid grid-cols-2 gap-4">
												<div>
													<div
														class="flex justify-between items-center mb-1"
													>
														<p
															class="text-xs text-gray-500"
														>
															Dimensione
														</p>
														<span
															id="fsh1-val"
															class="text-xs font-mono text-indigo-600"
															>{
																content.theme
																	.fsH1 ??
																	"4rem"
															}</span
														>
													</div>
													<input
														type="range"
														id="fsh1-range"
														name="theme_fsH1_raw"
														min="2.5"
														max="6"
														step="0.25"
														value={parseFloat(
															(
																content.theme
																	.fsH1 ??
																"4rem"
															).replace(
																"rem",
																"",
															),
														) || 4}
														class="w-full accent-indigo-500"
													/>
													<input
														type="hidden"
														name="theme_fsH1"
														id="fsh1-hidden"
														value={content.theme
