---
export const prerender = false;
import { getContent } from "../../content";
import About from "./components/About.astro";
import Contacts from "./components/Contacts.astro";
import Footer from "./components/Footer.astro";
import Gallery from "./components/Gallery.astro";
import Hero from "./components/Hero.astro";
import Menu from "./components/Menu.astro";
import Theme from "./components/Theme.astro";
import PreviewPanel from "./components/PreviewPanel.astro";
import Sidebar from "./components/Sidebar.astro";
import Topbar from "./components/Topbar.astro";
import ActionSidebar from "./components/ActionSidebar.astro";

const session = Astro.cookies.get("admin_session");
if (session?.value !== "authenticated") {
	return Astro.redirect("/admin/login");
}

const content = getContent("it");
const siteUrl = import.meta.env.SITE_URL || "/";
---

<html lang="it">
	<head>
		<title>Dashboard Admin | Ristogen</title>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<script is:inline src="https://cdn.tailwindcss.com"></script>
		<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"
		></script>
		<link
			href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css"
			rel="stylesheet"
		/>
	</head>
	<body class="h-screen overflow-hidden bg-gray-50 flex flex-col">
		<Topbar siteUrl={siteUrl} />
		<div class="flex flex-1 overflow-hidden">
			<!-- ── SIDEBAR ──────────────────────────────────────────────── -->
			<Sidebar />

			<!-- ── CONTROL PANEL ─────────────────────────────────────────── -->

			<main
				id="control-panel"
				class="flex-1 min-w-0 overflow-y-auto bg-gray-50 p-6"
			>
				<div class="w-full mx-auto flex flex-col gap-8">
					<Theme content={content} />
					<Hero content={content} />
					<About content={content} />
					<Menu content={content} />
					<Gallery content={content} />
					<Contacts content={content} />
					<Footer content={content} />
				</div>
			</main>

			<ActionSidebar />
			<!-- ── RESIZE HANDLE ─────────────────────────────────────────── -->
			<div
				id="resize-handle"
				class="hidden shrink-0 w-1.5 cursor-col-resize bg-gray-200 hover:bg-indigo-400 active:bg-indigo-500 transition-colors z-10"
				title="Trascina per ridimensionare"
			>
			</div>
			<!-- ── LIVE PREVIEW PANEL ───────────────────────────────────── -->
			<PreviewPanel />
		</div>
		<!-- Toastr container -->
		<div id="toastr" class="fixed top-6 right-6 z-50 flex flex-col gap-2">
		</div>
		<script>
			// ── TAB NAVIGATION ──────────────────────────────────────────────────
			// Gli script dei componenti (Sidebar, PreviewPanel, ThemeTypography, …)
			// sono autonomi. index.astro gestisce solo la navigazione fra sezioni,
			// il toastr e il submit dei form.
			const tabBtns = document.querySelectorAll<HTMLElement>(".tab-btn");
			const tabSections = document.querySelectorAll(".tab-section");
			let activeTab = tabBtns[0] as HTMLElement;

			function setActiveTab(btn: HTMLElement) {
				activeTab.classList.remove("bg-indigo-50", "text-indigo-700");
				btn.classList.add("bg-indigo-50", "text-indigo-700");
				activeTab = btn;
			}
			setActiveTab(activeTab);

			tabBtns.forEach((btn) => {
				btn.addEventListener("click", () => {
					tabSections.forEach((sec) => sec.classList.add("hidden"));
					const tabId = btn.dataset?.tab;
					if (tabId)
						document
							.getElementById(tabId)
							?.classList.remove("hidden");
					setActiveTab(btn);
				});
			});

			// ── TOASTR ──────────────────────────────────────────────────────────
			function showToastr(
				msg: string,
				type: "success" | "error" = "success",
			) {
				const toastr = document.getElementById("toastr");
				if (!toastr) return;
				const el = document.createElement("div");
				el.className = `px-4 py-2 rounded-lg shadow-lg font-semibold text-sm mb-2 flex items-center gap-2 transition-all duration-300 ${
					type === "success"
						? "bg-green-500 text-white"
						: "bg-red-500 text-white"
				}`;
				el.textContent = msg;
				toastr.appendChild(el);
				setTimeout(() => {
					el.classList.add("opacity-0");
					setTimeout(() => toastr.removeChild(el), 400);
				}, 2200);
			}

			// ── FORM SUBMIT ─────────────────────────────────────────────────────
			// Mappa: input element → file/files WebP convertiti (più affidabile di input.files=)
			const convertedFiles = new Map<HTMLInputElement, File | File[]>();

			document.querySelectorAll("form").forEach((form) => {
				form.addEventListener("submit", async (e) => {
					e.preventDefault();
					const btn = form.querySelector<HTMLButtonElement>(
						'button[type="submit"]',
					);
					if (btn) {
						btn.disabled = true;
						btn.textContent = "Sincronizzazione...";
					}
					const res = await fetch("/admin/api/cms-save", {
						method: "POST",
						body: buildFormData(form),
					});
					if (btn) {
						btn.disabled = false;
						btn.textContent = "Salva";
					}
					showToastr(
						res.ok ? "Salvato!" : "Errore salvataggio",
						res.ok ? "success" : "error",
					);
				});
			});

			// ── DRAG-TO-RESIZE ──────────────────────────────────────────────────
			// #resize-handle, #control-panel e #sidebar sono tutti in questa pagina.
			// + dragOverlay vive in PreviewPanel ma è accessibile via getElementById.
			const resizeHandle = document.getElementById("resize-handle");
			const controlPanel = document.getElementById("control-panel");
			const dragOverlay = document.getElementById("preview-drag-overlay");
			let isResizing = false;

			resizeHandle?.addEventListener("mousedown", (e) => {
				e.preventDefault();
				isResizing = true;
				document.body.style.cursor = "col-resize";
				document.body.style.userSelect = "none";
				// Blocca i pointer events sull'iframe durante il drag
				dragOverlay?.classList.remove("hidden");
			});

			document.addEventListener("mousemove", (e) => {
				if (!isResizing || !controlPanel) return;
				const sidebar = document.getElementById("sidebar");
				const previewPanel = document.getElementById("preview-panel");
				const container = controlPanel.parentElement;
				if (!container) return;

				// newW = larghezza desiderata per control-panel
				const sidebarW = sidebar?.offsetWidth ?? 0;
				const handleW = resizeHandle?.offsetWidth ?? 6;
				const totalW = container.offsetWidth;
				const containerLeft = container.getBoundingClientRect().left;
				let newW = e.clientX - containerLeft - sidebarW;

				// Snap a larghezze comuni
				const snap = [320, 380, 480, 600].find(
					(s) => Math.abs(newW - s) < 20,
				);
				if (snap) newW = snap;
				newW = Math.max(
					280,
					Math.min(totalW - sidebarW - handleW - 200, newW),
				);

				controlPanel.style.maxWidth = `${newW}px`;
				controlPanel.style.flexShrink = "0";
				if (previewPanel) {
					previewPanel.style.flex = "1";
					previewPanel.style.minWidth = "200px";
				}
			});

			document.addEventListener("mouseup", () => {
				if (!isResizing) return;
				isResizing = false;
				document.body.style.cursor = "";
				document.body.style.userSelect = "";
				dragOverlay?.classList.add("hidden");
			});

			// ── CLICK-TO-EDIT (postMessage dall'iframe preview) ──────────────────────────
			const FIELD_TAB: Record<string, string> = {
				hero_title: "hero",
				hero_message: "hero",
				hero_cta: "hero",
				about_preTitle: "about",
				about_text: "about",
				contatti_title: "contatti",
				contatti_address: "contatti",
				contatti_phone: "contatti",
				contatti_email: "contatti",
				contatti_hours: "contatti",
				footer_name: "footer",
				footer_copy: "footer",
				footer_instagram: "footer",
				footer_facebook: "footer",
			};

			// ── IMAGE & FILE DROPZONES ─────────────────────────────────────────────
			/** Costruisce un FormData sostituendo i file immagine con le versioni WebP convertite */
			function buildFormData(form: HTMLFormElement): FormData {
				const fd = new FormData();
				for (const el of Array.from(form.elements)) {
					const field = el as
						| HTMLInputElement
						| HTMLTextAreaElement
						| HTMLSelectElement;
					if (!field.name) continue;
					if (
						field instanceof HTMLInputElement &&
						field.type === "file"
					) {
						const converted = convertedFiles.get(field);
						if (converted) {
							// Usa il/i file convertiti in WebP
							if (Array.isArray(converted)) {
								converted.forEach((f) =>
									fd.append(field.name, f),
								);
							} else {
								fd.append(field.name, converted);
							}
						} else if (field.files?.length) {
							// Nessuna conversione effettuata: usa i file originali
							Array.from(field.files).forEach((f) =>
								fd.append(field.name, f),
							);
						}
					} else if (
						field instanceof HTMLInputElement &&
						field.type === "checkbox"
					) {
						if (field.checked) fd.append(field.name, field.value);
					} else if (
						field instanceof HTMLInputElement &&
						field.type === "radio"
					) {
						if (field.checked) fd.append(field.name, field.value);
					} else if ("value" in field && field.value !== undefined) {
						fd.append(
							field.name,
							(field as HTMLInputElement).value,
						);
					}
				}
				return fd;
			}

			function initDropzones() {
				document
					.querySelectorAll<HTMLElement>("[data-dropzone]")
					.forEach((dz) => {
						const type = dz.dataset.dropzone as
							| "image"
							| "images"
							| "file";
						const input =
							dz.querySelector<HTMLInputElement>(
								'input[type="file"]',
							);
						const emptyEl =
							dz.querySelector<HTMLElement>(".dz-empty");
						const filledEl =
							dz.querySelector<HTMLElement>(".dz-filled");
						if (!input) return;

						// Highlight durante drag
						dz.addEventListener("dragover", (e) => {
							e.preventDefault();
							dz.classList.add(
								"border-indigo-500",
								"bg-indigo-50",
							);
						});
						dz.addEventListener("dragleave", (e) => {
							if (!dz.contains(e.relatedTarget as Node))
								dz.classList.remove(
									"border-indigo-500",
									"bg-indigo-50",
								);
						});
						dz.addEventListener("drop", (e) => {
							e.preventDefault();
							dz.classList.remove(
								"border-indigo-500",
								"bg-indigo-50",
							);
							const files = e.dataTransfer?.files;
							if (files?.length) handleFiles(files);
						});

						// Selezione via file picker
						input.addEventListener("change", () => {
							if (input.files?.length) handleFiles(input.files);
						});

						async function handleFiles(files: FileList) {
							if (type === "image") {
								const file = files[0];
								if (!file.type.startsWith("image/")) return;

								// Mostra anteprima immediata + indicatore ottimizzazione
								emptyEl?.classList.add("hidden");
								filledEl?.classList.remove("hidden");
								const thumb =
									filledEl?.querySelector<HTMLImageElement>(
										".dz-thumb",
									);
								if (thumb) {
									thumb.src = URL.createObjectURL(file);
									thumb.style.opacity = "0.5";
								}
								setDzConverting(dz, true);

								const webpFile = await convertToWebP(file);
								convertedFiles.set(input, webpFile); // ← fonte di verità per buildFormData
								const dt = new DataTransfer();
								dt.items.add(webpFile);
								try {
									input.files = dt.files;
								} catch (_) {
									/* alcuni browser non lo permettono */
								}
								if (thumb) {
									thumb.src = URL.createObjectURL(webpFile);
									thumb.style.opacity = "";
								}
								setDzConverting(dz, false);
							} else if (type === "images") {
								const previews =
									filledEl?.querySelector<HTMLElement>(
										".dz-previews",
									);
								if (previews) previews.innerHTML = "";
								emptyEl?.classList.add("hidden");
								filledEl?.classList.remove("hidden");
								setDzConverting(dz, true);

								const imageFiles = Array.from(files).filter(
									(f) => f.type.startsWith("image/"),
								);
								const webpFiles = await Promise.all(
									imageFiles.map((f) => convertToWebP(f)),
								);
								const dt = new DataTransfer();
								webpFiles.forEach((webpFile) => {
									dt.items.add(webpFile);
									const img = document.createElement("img");
									img.src = URL.createObjectURL(webpFile);
									img.className =
										"w-20 h-20 object-cover rounded-lg flex-shrink-0";
									previews?.appendChild(img);
								});
								input.files = dt.files;
								convertedFiles.set(input, webpFiles); // ← fonte di verità per buildFormData
								setDzConverting(dz, false);
								if (dt.files.length === 0) {
									emptyEl?.classList.remove("hidden");
									filledEl?.classList.add("hidden");
								}
							} else if (type === "file") {
								const file = files[0];
								const dt = new DataTransfer();
								dt.items.add(file);
								input.files = dt.files;
								const nameEl =
									filledEl?.querySelector<HTMLElement>(
										".dz-filename",
									);
								const sizeEl =
									filledEl?.querySelector<HTMLElement>(
										".dz-filesize",
									);
								if (nameEl) nameEl.textContent = file.name;
								if (sizeEl)
									sizeEl.textContent = formatSize(file.size);
								emptyEl?.classList.add("hidden");
								if (filledEl) {
									filledEl.classList.remove("hidden");
									filledEl.style.display = "flex";
								}
							}
						}
					});
			}

			/** Mostra/nasconde badge "Ottimizzazione…" sulla dropzone */
			function setDzConverting(dz: HTMLElement, active: boolean) {
				let badge = dz.querySelector<HTMLElement>(".dz-converting");
				if (active && !badge) {
					badge = document.createElement("div");
					badge.className =
						"dz-converting absolute inset-0 z-20 flex items-center justify-center bg-black/40 pointer-events-none";
					badge.innerHTML =
						'<span class="flex items-center gap-1.5 text-white text-xs font-semibold">' +
						'<svg class="animate-spin w-3.5 h-3.5" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>' +
						"Ottimizzazione…</span>";
					dz.appendChild(badge);
				} else if (!active && badge) {
					badge.remove();
				}
			}

			/** Converte un File immagine in WebP tramite Canvas (client-side, 0 dipendenze) */
			async function convertToWebP(
				file: File,
				quality = 0.82,
			): Promise<File> {
				return new Promise((resolve, reject) => {
					const reader = new FileReader();
					reader.onerror = reject;
					reader.onload = (e) => {
						const img = new Image();
						img.onerror = reject;
						img.onload = () => {
							const canvas = document.createElement("canvas");
							canvas.width = img.naturalWidth;
							canvas.height = img.naturalHeight;
							canvas.getContext("2d")!.drawImage(img, 0, 0);
							canvas.toBlob(
								(blob) => {
									if (!blob)
										return reject(
											new Error(
												"Conversione WebP fallita",
											),
										);
									const name =
										file.name.replace(/\.[^/.]+$/, "") +
										".webp";
									resolve(
										new File([blob], name, {
											type: "image/webp",
										}),
									);
								},
								"image/webp",
								quality,
							);
						};
						img.src = e.target!.result as string;
					};
					reader.readAsDataURL(file);
				});
			}

			function formatSize(bytes: number): string {
				if (bytes < 1_048_576) return (bytes / 1024).toFixed(0) + " KB";
				return (bytes / 1_048_576).toFixed(1) + " MB";
			}

			initDropzones();

			// ── PUBLISH ALL (triggered by ActionSidebar "Pubblica su GitHub") ─────────
			/** Costruisce un FormData unificato raccogliendo tutti i form della pagina */
			function buildAllFormsData(): FormData {
				const fd = new FormData();
				const seen = new Set<string>(); // evita duplicati su campi radio/checkbox
				document
					.querySelectorAll<HTMLFormElement>("form")
					.forEach((form) => {
						for (const el of Array.from(form.elements)) {
							const field = el as
								| HTMLInputElement
								| HTMLTextAreaElement
								| HTMLSelectElement;
							if (!field.name) continue;
							if (
								field instanceof HTMLInputElement &&
								field.type === "file"
							) {
								const converted = convertedFiles.get(field);
								if (converted) {
									if (Array.isArray(converted))
										converted.forEach((f) =>
											fd.append(field.name, f),
										);
									else fd.append(field.name, converted);
								} else if (field.files?.length) {
									Array.from(field.files).forEach((f) =>
										fd.append(field.name, f),
									);
								}
							} else if (
								field instanceof HTMLInputElement &&
								field.type === "checkbox"
							) {
								if (field.checked)
									fd.append(field.name, field.value);
							} else if (
								field instanceof HTMLInputElement &&
								field.type === "radio"
							) {
								// Prendi solo il radio selezionato
								if (field.checked && !seen.has(field.name)) {
									fd.append(field.name, field.value);
									seen.add(field.name);
								}
							} else if (
								"value" in field &&
								field.value !== undefined
							) {
								fd.append(
									field.name,
									(field as HTMLInputElement).value,
								);
							}
						}
					});
				return fd;
			}

			async function publishAll() {
				document.dispatchEvent(new CustomEvent("ristogen:publishing"));
				try {
					const res = await fetch("/admin/api/cms-save", {
						method: "POST",
						body: buildAllFormsData(),
					});
					if (res.ok) {
						showToastr("Pubblicato su GitHub!", "success");
						document.dispatchEvent(
							new CustomEvent("ristogen:saved"),
						);
					} else {
						showToastr("Errore pubblicazione", "error");
						document.dispatchEvent(
							new CustomEvent("ristogen:save-error"),
						);
					}
				} catch {
					showToastr("Errore di rete", "error");
					document.dispatchEvent(
						new CustomEvent("ristogen:save-error"),
					);
				}
			}

			document.addEventListener("ristogen:publish", publishAll);

			// ── CLICK-TO-EDIT (postMessage dall'iframe preview) ──────────────────────────
			window.addEventListener("message", (e) => {
				if (e.origin !== location.origin) return;
				const data = e.data as { type?: string; field?: string };
				if (data?.type !== "editField" || !data.field) return;

				const field = data.field;
				const tabId = FIELD_TAB[field];
				if (!tabId) return;

				// Attiva il tab — simula click per riutilizzare la logica esistente
				const tabBtn = document.querySelector<HTMLElement>(
					`.tab-btn[data-tab="${tabId}"]`,
				);
				tabBtn?.click();

				// Dopo che il tab è visibile, trova e metti a fuoco l'input
				setTimeout(() => {
					// about_text usa Quill: punta all'editor invece dell'hidden input
					const inputEl =
						field === "about_text"
							? document.getElementById("editor-about")
							: document.querySelector<HTMLElement>(
									`[name="${field}"]`,
								);
					if (!inputEl) return;
					inputEl.scrollIntoView({
						behavior: "smooth",
						block: "center",
					});
					inputEl.classList.add(
						"ring-2",
						"ring-indigo-400",
						"ring-offset-2",
					);
					setTimeout(
						() =>
							inputEl.classList.remove(
								"ring-2",
								"ring-indigo-400",
								"ring-offset-2",
							),
						2000,
					);
					if ("focus" in inputEl) inputEl.focus();
				}, 60);
			});
		</script>
	</body>
</html>
