									class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
								/>
								<input
									type="email"
									name="contatti_email"
									value={content.sections.contatti
										.contatti_email}
									placeholder="Email"
									class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
								/>
								<input
									type="text"
									name="contatti_googleMapsEmbed"
									value={content.sections.contatti
										.contatti_googleMapsEmbed}
									placeholder="Google Maps Embed"
									class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
								/>
								{
									content.sections.contatti
										.contatti_googleMapsEmbed && (
										<div class="mb-4">
											<iframe
												src={
													content.sections.contatti
														.contatti_googleMapsEmbed
												}
												width="100%"
												height="200"
												style="border:0;"
												allowfullscreen
												loading="lazy"
											/>
										</div>
									)
								}
								<button
									type="submit"
									class="w-full py-2 rounded-md bg-indigo-500 hover:bg-indigo-600 font-semibold text-white transition"
									>Salva</button
								>
							</form>
						</div>
					</section>
					<section id="footer" class="tab-section hidden">
						<div
							class="rounded-xl border border-gray-200 bg-white shadow-sm p-7"
						>
							<h3 class="text-lg font-bold mb-6 text-gray-900">
								Footer
							</h3>
							<form id="form-footer" class="space-y-6">
								<input
									type="text"
									name="footer_name"
									value={content.sections.footer.footer_name}
									placeholder="Nome"
									class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
								/>
								<input
									type="text"
									name="footer_copy"
									value={content.sections.footer.footer_copy}
									placeholder="Copyright"
									class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
								/>
								<input
									type="text"
									name="footer_instagram"
									value={content.sections.footer.socials
										.footer_instagram}
									placeholder="Instagram"
									class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
								/>
								<input
									type="text"
									name="footer_facebook"
									value={content.sections.footer.socials
										.footer_facebook}
									placeholder="Facebook"
									class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
								/>
								{
									/* Footer: preview social, logo, se previsti in futuro */
								}
								{
									content.sections.footer.socials
										.footer_instagram && (
										<a
											href={
												content.sections.footer.socials
													.footer_instagram
											}
											target="_blank"
											rel="noopener"
											class="block mb-2 text-indigo-600 underline"
										>
											Instagram attuale
										</a>
									)
								}
								{
									content.sections.footer.socials
										.footer_facebook && (
										<a
											href={
												content.sections.footer.socials
													.footer_facebook
											}
											target="_blank"
											rel="noopener"
											class="block mb-2 text-indigo-600 underline"
										>
											Facebook attuale
										</a>
									)
								}
								<button
									type="submit"
									class="w-full py-2 rounded-md bg-indigo-500 hover:bg-indigo-600 font-semibold text-white transition"
									>Salva</button
								>
							</form>
						</div>
					</section>
				</div>
			</main>
		</div>
		<!-- Toastr container -->
		<div id="toastr" class="fixed top-6 right-6 z-50 flex flex-col gap-2">
		</div>
		<script>
			document.addEventListener("DOMContentLoaded", () => {
				// Tab logic
				const tabBtns = document.querySelectorAll(".tab-btn");
				const tabSections = document.querySelectorAll(".tab-section");
				let activeTab = tabBtns[0];
				function setActiveTab(btn) {
					activeTab.classList.remove(
						"bg-indigo-50",
						"text-indigo-700",
					);
					btn.classList.add("bg-indigo-50", "text-indigo-700");
					activeTab = btn;
				}
				setActiveTab(activeTab);

				// Font selector: toggle tra Google Fonts e upload personalizzato
				function initFontSelector(role: string, selectId: string) {
					const standardRadio = document.querySelector(
						`input[name="font_${role}_mode"][value="standard"]`,
					) as HTMLInputElement | null;
					const customRadio = document.querySelector(
						`input[name="font_${role}_mode"][value="custom"]`,
					) as HTMLInputElement | null;
					const standardPanel = document.getElementById(
						`${role}-standard-panel`,
					);
					const customPanel = document.getElementById(
						`${role}-custom-panel`,
					);
					const select = document.getElementById(
						selectId,
					) as HTMLSelectElement | null;

					function applyMode(mode: string) {
						if (mode === "standard") {
							standardPanel?.classList.remove("hidden");
							customPanel?.classList.add("hidden");
							if (select) select.disabled = false;
						} else {
							standardPanel?.classList.add("hidden");
							customPanel?.classList.remove("hidden");
							if (select) select.disabled = true;
						}
					}

					// Applica lo stato iniziale (sincronizza disabled con checked iniziale)
					applyMode(customRadio?.checked ? "custom" : "standard");

					standardRadio?.addEventListener("change", () =>
						applyMode("standard"),
					);
					customRadio?.addEventListener("change", () =>
						applyMode("custom"),
					);
				}

				initFontSelector("heading", "select-fontHeading");
				initFontSelector("body", "select-fontBody");

				// Slider: Section Padding (rem)
				const spRange = document.getElementById(
					"sp-range",
				) as HTMLInputElement | null;
				const spHidden = document.getElementById(
					"sp-hidden",
				) as HTMLInputElement | null;
				const spVal = document.getElementById("sp-val");
				spRange?.addEventListener("input", () => {
					const v = `${spRange.value}rem`;
					if (spHidden) spHidden.value = v;
					if (spVal) spVal.textContent = v;
				});

				// Slider: Spacing (rem)
				const spcRange = document.getElementById(
					"spc-range",
				) as HTMLInputElement | null;
				const spcHidden = document.getElementById(
					"spc-hidden",
				) as HTMLInputElement | null;
				const spcVal = document.getElementById("spc-val");
				spcRange?.addEventListener("input", () => {
					const v = `${spcRange.value}rem`;
					if (spcHidden) spcHidden.value = v;
					if (spcVal) spcVal.textContent = v;
				});

				// Slider: Border Radius (px)
				const radiusRange = document.getElementById(
					"radius-range",
				) as HTMLInputElement | null;
				const radiusHidden = document.getElementById(
					"radius-hidden",
				) as HTMLInputElement | null;
				const radiusVal = document.getElementById("radius-val");
				radiusRange?.addEventListener("input", () => {
					const v = `${radiusRange.value}px`;
					if (radiusHidden) radiusHidden.value = v;
					if (radiusVal) radiusVal.textContent = v;
				});

				// Slider: Font Size Base (px → rem)
				const fsRange = document.getElementById(
					"fs-base-range",
				) as HTMLInputElement | null;
				const fsHidden = document.getElementById(
					"fs-base-hidden",
				) as HTMLInputElement | null;
				const fsVal = document.getElementById("fs-base-val");
				fsRange?.addEventListener("input", () => {
					const px = parseFloat(fsRange.value);
					const rem = (px / 16).toFixed(4).replace(/\.?0+$/, "");
					const v = `${rem}rem`;
					if (fsHidden) fsHidden.value = v;
					if (fsVal) fsVal.textContent = v;
				});

				// Slider: Line Height Heading
				const lhHRange = document.getElementById(
					"lh-heading-range",
				) as HTMLInputElement | null;
				const lhHVal = document.getElementById("lh-heading-val");
				lhHRange?.addEventListener("input", () => {
					if (lhHVal) lhHVal.textContent = lhHRange.value;
				});

				// Slider: Line Height Body
				const lhBRange = document.getElementById(
					"lh-body-range",
				) as HTMLInputElement | null;
				const lhBVal = document.getElementById("lh-body-val");
				lhBRange?.addEventListener("input", () => {
					if (lhBVal) lhBVal.textContent = lhBRange.value;
				});

				// Gerarchia Titoli — slider rem (H1, H2, H3)
				const makeRemSlider = (
					rangeId: string,
					hiddenId: string,
					valId: string,
				) => {
					const range = document.getElementById(
						rangeId,
					) as HTMLInputElement | null;
					const hidden = document.getElementById(
						hiddenId,
					) as HTMLInputElement | null;
					const val = document.getElementById(valId);
					range?.addEventListener("input", () => {
						const v = `${range.value}rem`;
						if (hidden) hidden.value = v;
						if (val) val.textContent = v;
					});
				};
				makeRemSlider("fsh1-range", "fsh1-hidden", "fsh1-val");
				makeRemSlider("fsh2-range", "fsh2-hidden", "fsh2-val");
				makeRemSlider("fsh3-range", "fsh3-hidden", "fsh3-val");

				// Gerarchia Titoli — slider letter-spacing (centesimi di em)
				const makeLsSlider = (
					rangeId: string,
					hiddenId: string,
					valId: string,
				) => {
					const range = document.getElementById(
						rangeId,
					) as HTMLInputElement | null;
					const hidden = document.getElementById(
						hiddenId,
					) as HTMLInputElement | null;
					const val = document.getElementById(valId);
					range?.addEventListener("input", () => {
						const n = parseFloat(range.value) / 100;
						const v = `${n.toFixed(3).replace(/0+$/, "").replace(/\.$/, "") || "0"}em`;
						if (hidden) hidden.value = v;
						if (val) val.textContent = v;
					});
				};
				makeLsSlider("lsh1-range", "lsh1-hidden", "lsh1-val");
				makeLsSlider("lsh2-range", "lsh2-hidden", "lsh2-val");

				// Gerarchia Titoli — mobile scale (aggiorna solo label, valore va direttamente in FormData)
				const mobH1Range = document.getElementById(
					"mob-h1-range",
				) as HTMLInputElement | null;
				const mobH1Val = document.getElementById("mob-h1-val");
				mobH1Range?.addEventListener("input", () => {
					if (mobH1Val) mobH1Val.textContent = `${mobH1Range.value}%`;
				});
				const mobH2Range = document.getElementById(
					"mob-h2-range",
				) as HTMLInputElement | null;
				const mobH2Val = document.getElementById("mob-h2-val");
				mobH2Range?.addEventListener("input", () => {
					if (mobH2Val) mobH2Val.textContent = `${mobH2Range.value}%`;
				});

				tabBtns.forEach((btn) => {
					btn.addEventListener("click", () => {
						tabSections.forEach((sec) =>
							sec.classList.add("hidden"),
						);
						const tabId =
							btn instanceof HTMLElement && btn.dataset
								? btn.dataset.tab
								: null;
						if (tabId) {
							const tabSection = document.getElementById(tabId);
							if (tabSection)
								tabSection.classList.remove("hidden");
						}
						setActiveTab(btn);
					});
				});

				// Toastr feedback
				function showToastr(msg, type = "success") {
					const toastr = document.getElementById("toastr");
					const el = document.createElement("div");
					el.className = `px-4 py-2 rounded-lg shadow-lg font-semibold text-sm mb-2 flex items-center gap-2 transition-all duration-300 ${type === "success" ? "bg-green-500 text-white" : "bg-red-500 text-white"}`;
					el.textContent = msg;
					toastr.appendChild(el);
					setTimeout(() => {
						el.classList.add("opacity-0");
						setTimeout(() => toastr.removeChild(el), 400);
					}, 2200);
				}

				// Inizializza Quill editor per About
				// Usiamo text-change per tenere l'input nascosto sempre aggiornato
				// (evita race condition con il listener submit generico)
				const aboutInput = document.querySelector(
					'input[name="about_text"]',
				);
				const quill = new Quill("#editor-about", { theme: "snow" });
				if (aboutInput?.value) {
					quill.root.innerHTML = aboutInput.value;
				}
				quill.on("text-change", () => {
					if (aboutInput) aboutInput.value = quill.root.innerHTML;
				});
				// Logica di invio FormData e gestione stato pulsante
				document.querySelectorAll("form").forEach((form) => {
					form.addEventListener("submit", async (e) => {
						e.preventDefault();
						const btn = form.querySelector('button[type="submit"]');
						if (btn instanceof HTMLButtonElement) {
							btn.disabled = true;
							btn.textContent = "Sincronizzazione...";
						}
						const formData = new FormData(form);
						const res = await fetch("/admin/api/cms-save", {
							method: "POST",
							body: formData,
						});
						if (btn instanceof HTMLButtonElement) {
							btn.disabled = false;
							btn.textContent = "Salva";
						}
						if (res.ok) {
							showToastr("Salvato!", "success");
						} else {
							showToastr("Errore salvataggio", "error");
						}
					});
				});
			});
		</script>
	</body>
</html>
