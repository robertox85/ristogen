---
export const prerender = false;
import { getContent } from "../../content";

const session = Astro.cookies.get("admin_session");
if (session?.value !== "authenticated") {
	return Astro.redirect("/admin/login");
}

const content = getContent("it");
---

<html lang="it">
	<head>
		<title>Dashboard Admin | Ristogen</title>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<script is:inline src="https://cdn.tailwindcss.com"></script>
		<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"
		></script>
		<link
			href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css"
			rel="stylesheet"
		/>
	</head>
	<body class="h-screen overflow-hidden bg-gray-50">
		<div class="flex h-screen overflow-hidden">
			<!-- ── SIDEBAR ──────────────────────────────────────────────── -->
			<aside
				id="sidebar"
				class="w-52 shrink-0 bg-white border-r border-gray-200 flex flex-col transition-[width] duration-200 ease-in-out overflow-hidden"
			>
				<!-- Header sidebar: logo + toggle sempre visibili -->
				<div
					id="sidebar-header"
					class="flex items-center justify-between h-14 px-3 border-b border-gray-100 shrink-0"
				>
					<!-- Brand: nascosto quando collassata -->
					<div
						id="sidebar-brand"
						class="flex items-center gap-2 min-w-0 flex-1 overflow-hidden mr-2"
					>
						<div
							class="w-7 h-7 rounded-lg bg-indigo-600 flex items-center justify-center shrink-0"
						>
							<svg
								width="14"
								height="14"
								viewBox="0 0 24 24"
								fill="none"
								stroke="white"
								stroke-width="2.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								><path
									d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
								></path><polyline points="9 22 9 12 15 12 15 22"
								></polyline></svg
							>
						</div>
						<span
							class="text-sm font-bold text-gray-900 whitespace-nowrap overflow-hidden"
							>Ristogen</span
						>
					</div>
					<!-- Toggle: sempre visibile -->
					<button
						id="btn-sidebar-toggle"
						title="Comprimi/espandi"
						class="shrink-0 w-7 h-7 flex items-center justify-center rounded-md text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
					>
						<svg
							id="sidebar-toggle-icon"
							width="14"
							height="14"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							style="transition:transform 0.2s"
							><polyline points="15 18 9 12 15 6"></polyline></svg
						>
					</button>
				</div>

				<!-- Nav items -->
				<nav
					class="flex flex-col gap-0.5 p-2 flex-1 overflow-y-auto overflow-x-hidden"
				>
					{
						[
							{
								tab: "theme",
								icon: "M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z",
								label: "Theme",
							},
							{
								tab: "hero",
								icon: "M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z",
								label: "Hero",
							},
							{
								tab: "about",
								icon: "M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z",
								label: "About",
							},
							{
								tab: "gallery",
								icon: "M4 16l4.586-4.586a2 2 0 0 1 2.828 0L16 16m-2-2 1.586-1.586a2 2 0 0 1 2.828 0L20 14m-6-6h.01M6 20h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z",
								label: "Gallery",
							},
							{
								tab: "menu",
								icon: "M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2",
								label: "Menu",
							},
							{
								tab: "contatti",
								icon: "M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z",
								label: "Contatti",
							},
							{
								tab: "footer",
								icon: "M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1zM4 22v-7",
								label: "Footer",
							},
						].map(({ tab, icon, label }) => (
							<button
								class="tab-btn w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 hover:bg-indigo-50 hover:text-indigo-700 transition-colors"
								data-tab={tab}
								title={label}
							>
								<svg
									class="shrink-0"
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d={icon} />
								</svg>
								<span class="sidebar-label whitespace-nowrap">
									{label}
								</span>
							</button>
						))
					}
				</nav>

				<!-- Footer sidebar: Live Preview -->
				<div class="p-2 border-t border-gray-100 shrink-0">
					<button
						id="btn-preview-toggle"
						title="Live Preview"
						class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-semibold text-indigo-600 hover:bg-indigo-50 transition-colors"
					>
						<svg
							class="shrink-0"
							width="16"
							height="16"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path
								d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
							></path><circle cx="12" cy="12" r="3"></circle></svg
						>
						<span id="preview-label" class="sidebar-label"
							>Live Preview</span
						>
					</button>
				</div>
			</aside>

			<!-- ── CONTROL PANEL ─────────────────────────────────────────── -->
			<main
				id="control-panel"
				class="flex-1 min-w-0 overflow-y-auto bg-gray-50 p-6"
			>
				<div class="w-full max-w-2xl mx-auto flex flex-col gap-8">
					<section id="theme" class="tab-section">
						<div
							class="rounded-xl border border-gray-200 bg-white shadow-sm p-7"
						>
							<h3 class="text-lg font-bold mb-6 text-gray-900">
								Theme
							</h3>
							<form id="form-theme" class="space-y-8">
								<!-- ── COLORI BRAND ─────────────────────────────── -->
								<div>
									<p
										class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4"
									>
										Colori Brand
									</p>
									<div
										class="grid gap-6"
										style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr))"
									>
										<div class="flex items-center gap-3">
											<input
												type="color"
												name="theme_primary"
												value={content.theme.primary}
												class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
											/>
											<div>
												<p
													class="text-sm font-medium text-gray-700"
												>
													Colore Primario
												</p>
												<p
													class="text-xs text-gray-400"
												>
													Pulsanti, accenti
												</p>
											</div>
										</div>
										<div class="flex items-center gap-3">
											<input
												type="color"
												name="theme_secondary"
												value={content.theme.secondary}
												class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
											/>
											<div>
												<p
													class="text-sm font-medium text-gray-700"
												>
													Colore Secondario
												</p>
												<p
													class="text-xs text-gray-400"
												>
													Elementi decorativi
												</p>
											</div>
										</div>
										<div class="flex items-center gap-3">
											<input
												type="color"
												name="theme_bg"
												value={content.theme.bg}
												class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
											/>
											<div>
												<p
													class="text-sm font-medium text-gray-700"
												>
													Sfondo
												</p>
												<p
													class="text-xs text-gray-400"
												>
													Colore di fondo pagina
												</p>
											</div>
										</div>
										<div class="flex items-center gap-3">
											<input
												type="color"
												name="theme_text"
												value={content.theme.text}
												class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
											/>
											<div>
												<p
													class="text-sm font-medium text-gray-700"
												>
													Testo
												</p>
												<p
													class="text-xs text-gray-400"
												>
													Colore testo principale
												</p>
											</div>
										</div>
									</div>
								</div>

								<!-- ── TIPOGRAFIA ────────────────────────────────── -->
								<div>
									<p
										class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4"
									>
										Tipografia
									</p>
									<div
										class="lg:grid gap-6"
										style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr))"
									>
										<!-- Font Heading card -->
										<div
											class="rounded-lg border border-gray-200 bg-gray-50 p-4"
										>
											<p
												class="text-sm font-semibold text-gray-700 mb-3"
											>
												Font Titoli
											</p>
											<div class="lg:flex gap-4 mb-3">
												<label
													class="lg:flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
												>
													<input
														type="radio"
														name="font_heading_mode"
														value="standard"
														checked={!content.theme
															.customFonts
															?.heading}
													/>
													Standard
												</label>
												<label
													class="lg:flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
												>
													<input
														type="radio"
														name="font_heading_mode"
														value="custom"
														checked={!!content.theme
															.customFonts
															?.heading}
													/>
													Custom
												</label>
											</div>
											<div id="heading-standard-panel">
												<select
													name="theme_fontHeading"
													id="select-fontHeading"
													class="w-full px-3 py-2 rounded-md border border-gray-200 bg-white text-gray-900 text-sm"
												>
													<option
														value="'Playfair Display', serif"
														selected={content.theme
															.fontHeading ===
															"'Playfair Display', serif"}
														>Playfair Display</option
													>
													<option
														value="'Montserrat', sans-serif"
														selected={content.theme
															.fontHeading ===
															"'Montserrat', sans-serif"}
														>Montserrat</option
													>
													<option
														value="'Cormorant Garamond', serif"
														selected={content.theme
															.fontHeading ===
															"'Cormorant Garamond', serif"}
														>Cormorant Garamond</option
													>
													<option
														value="'Inter', sans-serif"
														selected={content.theme
															.fontHeading ===
															"'Inter', sans-serif"}
														>Inter</option
													>
													<option
														value="'Lora', serif"
														selected={content.theme
															.fontHeading ===
															"'Lora', serif"}
														>Lora</option
													>
													<option
														value="'Oswald', sans-serif"
														selected={content.theme
															.fontHeading ===
															"'Oswald', sans-serif"}
														>Oswald</option
													>
												</select>
											</div>
											<div
												id="heading-custom-panel"
												class="hidden"
											>
												<input
													type="file"
													name="font_heading_file"
													accept=".ttf,.woff2"
													class="w-full text-sm text-gray-900"
												/>
												{
													content.theme.customFonts
														?.heading && (
														<p class="text-xs text-green-600 mt-1">
															Caricato:{" "}
															{
																content.theme
																	.customFonts
																	.heading
															}
															{content.theme
																.customFonts
																.headingType && (
																<span class="ml-1 px-1.5 py-0.5 rounded bg-green-100 text-green-700 font-mono">
																	{
																		content
																			.theme
																			.customFonts
																			.headingType
																	}
																</span>
															)}
														</p>
													)
												}
											</div>
											<!-- Peso -->
											<div class="mt-4">
												<p
													class="text-xs text-gray-500 mb-1"
												>
													Peso carattere titoli
												</p>
												<div class="flex gap-2">
													{
														[
															["300", "Sottile"],
															["400", "Regolare"],
															[
																"700",
																"Grassetto",
															],
															[
																"900",
																"Extra Grassetto",
															],
														].map(
															([val, label]) => (
																<label class="flex-1 text-center cursor-pointer">
																	<input
																		type="radio"
																		name="theme_fontWeightHeading"
																		value={
																			val
																		}
																		checked={
																			content
																				.theme
																				.fontWeightHeading ===
																				val ||
																			(!content
																				.theme
																				.fontWeightHeading &&
																				val ===
																					"700")
																		}
																		class="sr-only peer"
																	/>
																	<span class="block py-1.5 px-1 rounded-md border border-gray-200 text-xs text-gray-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 transition">
																		{label}
																	</span>
																</label>
															),
														)
													}
												</div>
											</div>
											<!-- Interlinea -->
											<div class="mt-4">
												<div
													class="flex justify-between items-center mb-1"
												>
													<p
														class="text-xs text-gray-500"
													>
														Interlinea titoli
													</p>
													<span
														id="lh-heading-val"
														class="text-xs font-mono text-indigo-600"
														>{
															content.theme
																.lineHeightHeading ??
																"1.2"
														}</span
													>
												</div>
												<input
													type="range"
													name="theme_lineHeightHeading"
													min="1"
													max="2"
													step="0.1"
													value={content.theme
														.lineHeightHeading ??
														"1.2"}
													class="w-full accent-indigo-500"
													id="lh-heading-range"
												/>
											</div>
										</div>

										<!-- Font Body card -->
										<div
											class="rounded-lg border border-gray-200 bg-gray-50 p-4"
										>
											<p
												class="text-sm font-semibold text-gray-700 mb-3"
											>
												Font Testo
											</p>
											<div class="flex gap-4 mb-3">
												<label
													class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
												>
													<input
														type="radio"
														name="font_body_mode"
														value="standard"
														checked={!content.theme
															.customFonts?.body}
													/>
													Standard
												</label>
												<label
													class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
												>
													<input
														type="radio"
														name="font_body_mode"
														value="custom"
														checked={!!content.theme
															.customFonts?.body}
													/>
													Custom
												</label>
											</div>
											<div id="body-standard-panel">
												<select
													name="theme_fontBody"
													id="select-fontBody"
													class="w-full px-3 py-2 rounded-md border border-gray-200 bg-white text-gray-900 text-sm"
												>
													<option
														value="'Playfair Display', serif"
														selected={content.theme
															.fontBody ===
															"'Playfair Display', serif"}
														>Playfair Display</option
													>
													<option
														value="'Montserrat', sans-serif"
														selected={content.theme
															.fontBody ===
															"'Montserrat', sans-serif"}
														>Montserrat</option
													>
													<option
														value="'Cormorant Garamond', serif"
														selected={content.theme
															.fontBody ===
															"'Cormorant Garamond', serif"}
														>Cormorant Garamond</option
													>
													<option
														value="'Inter', sans-serif"
														selected={content.theme
															.fontBody ===
															"'Inter', sans-serif"}
														>Inter</option
													>
													<option
														value="'Lora', serif"
														selected={content.theme
															.fontBody ===
															"'Lora', serif"}
														>Lora</option
													>
													<option
														value="'Oswald', sans-serif"
														selected={content.theme
															.fontBody ===
															"'Oswald', sans-serif"}
														>Oswald</option
													>
												</select>
											</div>
											<div
												id="body-custom-panel"
												class="hidden"
											>
												<input
													type="file"
													name="font_body_file"
													accept=".ttf,.woff2"
													class="w-full text-sm text-gray-900"
												/>
												{
													content.theme.customFonts
														?.body && (
														<p class="text-xs text-green-600 mt-1">
															Caricato:{" "}
															{
																content.theme
																	.customFonts
																	.body
															}
															{content.theme
																.customFonts
																.bodyType && (
																<span class="ml-1 px-1.5 py-0.5 rounded bg-green-100 text-green-700 font-mono">
																	{
																		content
																			.theme
																			.customFonts
																			.bodyType
																	}
																</span>
															)}
														</p>
													)
												}
											</div>
											<!-- Peso -->
											<div class="mt-4">
												<p
													class="text-xs text-gray-500 mb-1"
												>
													Peso carattere testo
												</p>
												<div class="flex gap-2">
													{
														[
															["300", "Sottile"],
															["400", "Regolare"],
															[
																"700",
																"Grassetto",
															],
															[
																"900",
																"Extra Grassetto",
															],
														].map(
															([val, label]) => (
																<label class="flex-1 text-center cursor-pointer">
																	<input
																		type="radio"
																		name="theme_fontWeightBody"
																		value={
																			val
																		}
																		checked={
																			content
																				.theme
																				.fontWeightBody ===
																				val ||
																			(!content
																				.theme
																				.fontWeightBody &&
																				val ===
																					"400")
																		}
																		class="sr-only peer"
																	/>
																	<span class="block py-1.5 px-1 rounded-md border border-gray-200 text-xs text-gray-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 transition">
																		{label}
																	</span>
																</label>
															),
														)
													}
												</div>
											</div>
											<!-- Interlinea -->
											<div class="mt-4">
												<div
													class="flex justify-between items-center mb-1"
												>
													<p
														class="text-xs text-gray-500"
													>
														Interlinea testo
													</p>
													<span
														id="lh-body-val"
														class="text-xs font-mono text-indigo-600"
														>{
															content.theme
																.lineHeightBody ??
																"1.6"
														}</span
													>
												</div>
												<input
													type="range"
													name="theme_lineHeightBody"
													min="1"
													max="2.5"
													step="0.1"
													value={content.theme
														.lineHeightBody ??
														"1.6"}
													class="w-full accent-indigo-500"
