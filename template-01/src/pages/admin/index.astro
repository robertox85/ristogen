---
export const prerender = false;
import { getContent } from "../../content";
import About from "./components/About.astro";
import Contacts from "./components/Contacts.astro";
import Footer from "./components/Footer.astro";
import Gallery from "./components/Gallery.astro";
import Hero from "./components/Hero.astro";
import Menu from "./components/Menu.astro";
import Theme from "./components/Theme.astro";
import PreviewPanel from "./components/PreviewPanel.astro";
import Sidebar from "./components/Sidebar.astro";
import Topbar from "./components/Topbar.astro";

const session = Astro.cookies.get("admin_session");
if (session?.value !== "authenticated") {
	return Astro.redirect("/admin/login");
}

const content = getContent("it");
const siteUrl = import.meta.env.SITE_URL || "/";
---

<html lang="it">
	<head>
		<title>Dashboard Admin | Ristogen</title>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<script is:inline src="https://cdn.tailwindcss.com"></script>
		<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"
		></script>
		<link
			href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css"
			rel="stylesheet"
		/>
	</head>
	<body class="h-screen overflow-hidden bg-gray-50 flex flex-col">
		<Topbar siteUrl={siteUrl} />
		<div class="flex flex-1 overflow-hidden">
			<!-- ── SIDEBAR ──────────────────────────────────────────────── -->
			<Sidebar />

			<!-- ── CONTROL PANEL ─────────────────────────────────────────── -->

			<main
				id="control-panel"
				class="flex-1 min-w-0 overflow-y-auto bg-gray-50 p-6"
			>
				<div class="w-full max-w-2xl mx-auto flex flex-col gap-8">
					<Theme content={content} />
					<Hero content={content} />
					<About content={content} />
					<Menu content={content} />
					<Gallery content={content} />
					<Contacts content={content} />
					<Footer content={content} />
				</div>
			</main>
			<!-- ── RESIZE HANDLE ─────────────────────────────────────────── -->
			<div
				id="resize-handle"
				class="hidden shrink-0 w-1.5 cursor-col-resize bg-gray-200 hover:bg-indigo-400 active:bg-indigo-500 transition-colors z-10"
				title="Trascina per ridimensionare"
			>
			</div>
			<!-- ── LIVE PREVIEW PANEL ───────────────────────────────────── -->
			<PreviewPanel />
		</div>
		<!-- Toastr container -->
		<div id="toastr" class="fixed top-6 right-6 z-50 flex flex-col gap-2">
		</div>
		<script>
			// ── TAB NAVIGATION ──────────────────────────────────────────────────
			// Gli script dei componenti (Sidebar, PreviewPanel, ThemeTypography, …)
			// sono autonomi. index.astro gestisce solo la navigazione fra sezioni,
			// il toastr e il submit dei form.
			const tabBtns = document.querySelectorAll<HTMLElement>(".tab-btn");
			const tabSections = document.querySelectorAll(".tab-section");
			let activeTab = tabBtns[0] as HTMLElement;

			function setActiveTab(btn: HTMLElement) {
				activeTab.classList.remove("bg-indigo-50", "text-indigo-700");
				btn.classList.add("bg-indigo-50", "text-indigo-700");
				activeTab = btn;
			}
			setActiveTab(activeTab);

			tabBtns.forEach((btn) => {
				btn.addEventListener("click", () => {
					tabSections.forEach((sec) => sec.classList.add("hidden"));
					const tabId = btn.dataset?.tab;
					if (tabId)
						document
							.getElementById(tabId)
							?.classList.remove("hidden");
					setActiveTab(btn);
				});
			});

			// ── TOASTR ──────────────────────────────────────────────────────────
			function showToastr(
				msg: string,
				type: "success" | "error" = "success",
			) {
				const toastr = document.getElementById("toastr");
				if (!toastr) return;
				const el = document.createElement("div");
				el.className = `px-4 py-2 rounded-lg shadow-lg font-semibold text-sm mb-2 flex items-center gap-2 transition-all duration-300 ${
					type === "success"
						? "bg-green-500 text-white"
						: "bg-red-500 text-white"
				}`;
				el.textContent = msg;
				toastr.appendChild(el);
				setTimeout(() => {
					el.classList.add("opacity-0");
					setTimeout(() => toastr.removeChild(el), 400);
				}, 2200);
			}

			// ── FORM SUBMIT ─────────────────────────────────────────────────────
			document.querySelectorAll("form").forEach((form) => {
				form.addEventListener("submit", async (e) => {
					e.preventDefault();
					const btn = form.querySelector<HTMLButtonElement>(
						'button[type="submit"]',
					);
					if (btn) {
						btn.disabled = true;
						btn.textContent = "Sincronizzazione...";
					}
					const res = await fetch("/admin/api/cms-save", {
						method: "POST",
						body: new FormData(form),
					});
					if (btn) {
						btn.disabled = false;
						btn.textContent = "Salva";
					}
					showToastr(
						res.ok ? "Salvato!" : "Errore salvataggio",
						res.ok ? "success" : "error",
					);
				});
			});

			// ── DRAG-TO-RESIZE ──────────────────────────────────────────────────
			// #resize-handle, #control-panel e #sidebar sono tutti in questa pagina.
			// + dragOverlay vive in PreviewPanel ma è accessibile via getElementById.
			const resizeHandle = document.getElementById("resize-handle");
			const controlPanel = document.getElementById("control-panel");
			const dragOverlay = document.getElementById("preview-drag-overlay");
			let isResizing = false;

			resizeHandle?.addEventListener("mousedown", (e) => {
				e.preventDefault();
				isResizing = true;
				document.body.style.cursor = "col-resize";
				document.body.style.userSelect = "none";
				// Blocca i pointer events sull'iframe durante il drag
				dragOverlay?.classList.remove("hidden");
			});

			document.addEventListener("mousemove", (e) => {
				if (!isResizing || !controlPanel) return;
				const sidebar = document.getElementById("sidebar");
				const previewPanel = document.getElementById("preview-panel");
				const container = controlPanel.parentElement;
				if (!container) return;

				// newW = larghezza desiderata per control-panel
				const sidebarW = sidebar?.offsetWidth ?? 0;
				const handleW = resizeHandle?.offsetWidth ?? 6;
				const totalW = container.offsetWidth;
				const containerLeft = container.getBoundingClientRect().left;
				let newW = e.clientX - containerLeft - sidebarW;

				// Snap a larghezze comuni
				const snap = [320, 380, 480, 600].find(
					(s) => Math.abs(newW - s) < 20,
				);
				if (snap) newW = snap;
				newW = Math.max(
					280,
					Math.min(totalW - sidebarW - handleW - 200, newW),
				);

				controlPanel.style.maxWidth = `${newW}px`;
				controlPanel.style.flexShrink = "0";
				if (previewPanel) {
					previewPanel.style.flex = "1";
					previewPanel.style.minWidth = "200px";
				}
			});

			document.addEventListener("mouseup", () => {
				if (!isResizing) return;
				isResizing = false;
				document.body.style.cursor = "";
				document.body.style.userSelect = "";
				dragOverlay?.classList.add("hidden");
			});

			// ── CLICK-TO-EDIT (postMessage dall'iframe preview) ──────────────────────────
			const FIELD_TAB: Record<string, string> = {
				hero_title: "hero",
				hero_message: "hero",
				hero_cta: "hero",
				about_preTitle: "about",
				about_text: "about",
				contatti_title: "contatti",
				contatti_address: "contatti",
				contatti_phone: "contatti",
				contatti_email: "contatti",
				contatti_hours: "contatti",
				footer_name: "footer",
				footer_copy: "footer",
				footer_instagram: "footer",
				footer_facebook: "footer",
			};

			// ── IMAGE & FILE DROPZONES ─────────────────────────────────────────────
			function initDropzones() {
				document
					.querySelectorAll<HTMLElement>("[data-dropzone]")
					.forEach((dz) => {
						const type = dz.dataset.dropzone as
							| "image"
							| "images"
							| "file";
						const input =
							dz.querySelector<HTMLInputElement>(
								'input[type="file"]',
							);
						const emptyEl =
							dz.querySelector<HTMLElement>(".dz-empty");
						const filledEl =
							dz.querySelector<HTMLElement>(".dz-filled");
						if (!input) return;

						// Highlight durante drag
						dz.addEventListener("dragover", (e) => {
							e.preventDefault();
							dz.classList.add(
								"border-indigo-500",
								"bg-indigo-50",
							);
						});
						dz.addEventListener("dragleave", (e) => {
							if (!dz.contains(e.relatedTarget as Node))
								dz.classList.remove(
									"border-indigo-500",
									"bg-indigo-50",
								);
						});
						dz.addEventListener("drop", (e) => {
							e.preventDefault();
							dz.classList.remove(
								"border-indigo-500",
								"bg-indigo-50",
							);
							const files = e.dataTransfer?.files;
							if (files?.length) handleFiles(files);
						});

						// Selezione via file picker
						input.addEventListener("change", () => {
							if (input.files?.length) handleFiles(input.files);
						});

						function handleFiles(files: FileList) {
							if (type === "image") {
								const file = files[0];
								if (!file.type.startsWith("image/")) return;
								const dt = new DataTransfer();
								dt.items.add(file);
								input.files = dt.files;
								const thumb =
									filledEl?.querySelector<HTMLImageElement>(
										".dz-thumb",
									);
								if (thumb)
									thumb.src = URL.createObjectURL(file);
								emptyEl?.classList.add("hidden");
								filledEl?.classList.remove("hidden");
							} else if (type === "images") {
								const previews =
									filledEl?.querySelector<HTMLElement>(
										".dz-previews",
									);
								if (previews) previews.innerHTML = "";
								const dt = new DataTransfer();
								Array.from(files).forEach((file) => {
									if (!file.type.startsWith("image/")) return;
									dt.items.add(file);
									const img = document.createElement("img");
									img.src = URL.createObjectURL(file);
									img.className =
										"w-20 h-20 object-cover rounded-lg flex-shrink-0";
									previews?.appendChild(img);
								});
								input.files = dt.files;
								if (dt.files.length > 0) {
									emptyEl?.classList.add("hidden");
									filledEl?.classList.remove("hidden");
								}
							} else if (type === "file") {
								const file = files[0];
								const dt = new DataTransfer();
								dt.items.add(file);
								input.files = dt.files;
								const nameEl =
									filledEl?.querySelector<HTMLElement>(
										".dz-filename",
									);
								const sizeEl =
									filledEl?.querySelector<HTMLElement>(
										".dz-filesize",
									);
								if (nameEl) nameEl.textContent = file.name;
								if (sizeEl)
									sizeEl.textContent = formatSize(file.size);
								emptyEl?.classList.add("hidden");
								if (filledEl) {
									filledEl.classList.remove("hidden");
									filledEl.style.display = "flex";
								}
							}
						}
					});
			}

			function formatSize(bytes: number): string {
				if (bytes < 1_048_576) return (bytes / 1024).toFixed(0) + " KB";
				return (bytes / 1_048_576).toFixed(1) + " MB";
			}

			initDropzones();

			// ── CLICK-TO-EDIT (postMessage dall'iframe preview) ──────────────────────────
			window.addEventListener("message", (e) => {
				if (e.origin !== location.origin) return;
				const data = e.data as { type?: string; field?: string };
				if (data?.type !== "editField" || !data.field) return;

				const field = data.field;
				const tabId = FIELD_TAB[field];
				if (!tabId) return;

				// Attiva il tab — simula click per riutilizzare la logica esistente
				const tabBtn = document.querySelector<HTMLElement>(
					`.tab-btn[data-tab="${tabId}"]`,
				);
				tabBtn?.click();

				// Dopo che il tab è visibile, trova e metti a fuoco l'input
				setTimeout(() => {
					// about_text usa Quill: punta all'editor invece dell'hidden input
					const inputEl =
						field === "about_text"
							? document.getElementById("editor-about")
							: document.querySelector<HTMLElement>(
									`[name="${field}"]`,
								);
					if (!inputEl) return;
					inputEl.scrollIntoView({
						behavior: "smooth",
						block: "center",
					});
					inputEl.classList.add(
						"ring-2",
						"ring-indigo-400",
						"ring-offset-2",
					);
					setTimeout(
						() =>
							inputEl.classList.remove(
								"ring-2",
								"ring-indigo-400",
								"ring-offset-2",
							),
						2000,
					);
					if ("focus" in inputEl) inputEl.focus();
				}, 60);
			});
		</script>
	</body>
</html>
