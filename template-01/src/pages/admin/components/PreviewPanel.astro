---
export const prerender = false;

---

<div
	id="preview-panel"
	class="flex flex-col overflow-hidden bg-gray-900 border-l border-gray-200 hidden"
	style="width:60%"
>
	<!-- Toolbar -->
	<div
		class="flex items-center gap-2 px-4 h-11 bg-white border-b border-gray-200 shrink-0"
	>
		<span
			class="text-xs font-bold uppercase tracking-widest text-gray-400 mr-2"
			>Preview</span
		>
		<!-- Viewport switcher -->
		<div
			class="flex items-center rounded-md border border-gray-200 overflow-hidden"
		>
			<button
				id="btn-desktop"
				title="Desktop"
				class="px-2.5 py-1.5 transition bg-indigo-50 text-indigo-700 border-r border-gray-200"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="w-4 h-4"
				>
					<rect x="2" y="3" width="20" height="14" rx="2"></rect><path
						d="M8 21h8M12 17v4"></path>
				</svg>
			</button>
			<button
				id="btn-tablet"
				title="Tablet (768px)"
				class="px-2.5 py-1.5 transition text-gray-500 hover:bg-gray-50 border-r border-gray-200"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="w-4 h-4"
				>
					<rect x="4" y="2" width="16" height="20" rx="2"></rect><line
						x1="12"
						y1="18"
						x2="12"
						y2="18.01"
						stroke-width="3"
						stroke-linecap="round"></line>
				</svg>
			</button>
			<button
				id="btn-mobile"
				title="Mobile (375px)"
				class="px-2.5 py-1.5 transition text-gray-500 hover:bg-gray-50"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="w-4 h-4"
				>
					<rect x="7" y="2" width="10" height="20" rx="2"></rect><line
						x1="12"
						y1="18"
						x2="12"
						y2="18.01"
						stroke-width="3"
						stroke-linecap="round"></line>
				</svg>
			</button>
		</div>
		<button
			id="btn-typography"
			class="px-2.5 py-1 text-xs rounded-md border font-medium transition text-gray-600 border-gray-200 hover:bg-gray-50"
			>Aa Tipografia</button
		>
		<div class="ml-auto">
			<button
				id="btn-close-preview"
				title="Chiudi preview"
				class="px-2.5 py-1 text-xs rounded-md border font-medium transition text-gray-500 border-gray-200 hover:bg-red-50 hover:text-red-600 hover:border-red-200"
				>✕ Chiudi</button
			>
		</div>
	</div>
	<!-- iframe container -->
	<div
		class="flex-1 flex items-start justify-center overflow-auto p-4 bg-gray-800"
	>
		<div
			id="preview-wrapper"
			style="width:100%;height:100%"
			class="relative transition-all duration-300"
		>
			<iframe
				id="preview-frame"
				src="/"
				title="Live Preview"
				class="w-full h-full rounded-lg shadow-xl border-0 bg-white"
			></iframe>
			<!-- Overlay anti-iframe: blocca i pointer events durante il drag-resize -->
			<div
				id="preview-drag-overlay"
				class="hidden absolute inset-0 z-10 cursor-col-resize"
			>
			</div>
		</div>
	</div>
</div>

<script>
	// ── LIVE PREVIEW: iniezione CSS vars tramite postMessage ──────────────────
	const previewFrame = document.getElementById(
		"preview-frame",
	) as HTMLIFrameElement | null;
	const previewWrapper = document.getElementById(
		"preview-wrapper",
	) as HTMLElement | null;

	function previewSetVar(cssVar: string, value: string) {
		previewFrame?.contentWindow?.postMessage(
			{ type: "setVar", name: cssVar, value },
			location.origin,
		);
	}

	function previewLoadFont(fontFamily: string) {
		previewFrame?.contentWindow?.postMessage(
			{ type: "loadFont", fontFamily },
			location.origin,
		);
	}

	/** Mappa: nome del campo FormData → CSS var corrispondente nel preview */
	const THEME_VAR_MAP: Record<
		string,
		{ cssVar: string; transform?: (v: string) => string }
	> = {
		theme_primary: { cssVar: "--color-primary" },
		theme_secondary: { cssVar: "--color-secondary" },
		theme_bg: { cssVar: "--color-bg" },
		theme_text: { cssVar: "--color-text" },
		theme_fontWeightHeading: { cssVar: "--font-weight-heading" },
		theme_fontWeightBody: { cssVar: "--font-weight-body" },
		theme_lineHeightHeading: { cssVar: "--line-height-heading" },
		theme_lineHeightBody: { cssVar: "--line-height-body" },
		theme_textAlign: { cssVar: "--text-align-base" },
		theme_fontSizeBase: { cssVar: "--font-size-base" },
		theme_sectionPadding: { cssVar: "--section-padding" },
		theme_spacing: { cssVar: "--spacing-base" },
		theme_radius: { cssVar: "--radius-base" },
		theme_fsH1: { cssVar: "--fs-h1" },
		theme_fsH2: { cssVar: "--fs-h2" },
		theme_fsH3: { cssVar: "--fs-h3" },
		theme_letterSpacingH1: { cssVar: "--ls-h1" },
		theme_letterSpacingH2: { cssVar: "--ls-h2" },
		theme_mobileScaleH1: {
			cssVar: "--mobile-scale-h1",
			transform: (v) => (parseFloat(v) / 100).toFixed(2),
		},
		theme_mobileScaleH2: {
			cssVar: "--mobile-scale-h2",
			transform: (v) => (parseFloat(v) / 100).toFixed(2),
		},
	};

	/**
	 * Range slider senza `name` (non compaiono in FormData): ascoltati direttamente
	 * per iniettare la CSS var nel preview senza passare dagli input nascosti.
	 * [rangeId, cssVar, transform?]
	 */
	const RANGE_PREVIEW: [string, string, ((v: string) => string)?][] = [
		["sp-range", "--section-padding", (v) => `${v}rem`],
		["spc-range", "--spacing-base", (v) => `${v}rem`],
		["radius-range", "--radius-base", (v) => `${v}px`],
		[
			"fs-base-range",
			"--font-size-base",
			(v) =>
				`${(parseFloat(v) / 16).toFixed(4).replace(/\.?0+$/, "")}rem`,
		],
		["fsh1-range", "--fs-h1", (v) => `${v}rem`],
		["fsh2-range", "--fs-h2", (v) => `${v}rem`],
		["fsh3-range", "--fs-h3", (v) => `${v}rem`],
		[
			"lsh1-range",
			"--ls-h1",
			(v) => {
				const n = parseFloat(v) / 100;
				return `${n.toFixed(3).replace(/0+$/, "").replace(/\.$/, "") || "0"}em`;
			},
		],
		[
			"lsh2-range",
			"--ls-h2",
			(v) => {
				const n = parseFloat(v) / 100;
				return `${n.toFixed(3).replace(/0+$/, "").replace(/\.$/, "") || "0"}em`;
			},
		],
		[
			"mob-h1-range",
			"--mobile-scale-h1",
			(v) => (parseFloat(v) / 100).toFixed(2),
		],
		[
			"mob-h2-range",
			"--mobile-scale-h2",
			(v) => (parseFloat(v) / 100).toFixed(2),
		],
		["lh-heading-range", "--line-height-heading"],
		["lh-body-range", "--line-height-body"],
	];

	/** Re-invia al frame tutti i valori correnti di #form-theme */
	function applyAllVarsToPreview() {
		const form = document.getElementById(
			"form-theme",
		) as HTMLFormElement | null;
		if (!form) return;

		new FormData(form).forEach((value, key) => {
			if (typeof value !== "string") return;
			if (key === "theme_fontHeading") {
				previewSetVar("--font-heading", value);
				previewLoadFont(value);
				return;
			}
			if (key === "theme_fontBody") {
				previewSetVar("--font-body", value);
				previewLoadFont(value);
				return;
			}
			const entry = THEME_VAR_MAP[key];
			if (entry)
				previewSetVar(
					entry.cssVar,
					entry.transform ? entry.transform(value) : value,
				);
		});
	}

	// Ogni input nel form-theme → inject live al primo cambiamento
	document.getElementById("form-theme")?.addEventListener("input", (e) => {
		const target = e.target as HTMLInputElement;
		const name = target.name;
		if (!name) return;
		if (name === "theme_fontHeading") {
			previewSetVar("--font-heading", target.value);
			previewLoadFont(target.value);
			return;
		}
		if (name === "theme_fontBody") {
			previewSetVar("--font-body", target.value);
			previewLoadFont(target.value);
			return;
		}
		const entry = THEME_VAR_MAP[name];
		if (entry)
			previewSetVar(
				entry.cssVar,
				entry.transform ? entry.transform(target.value) : target.value,
			);
	});

	// Range slider diretti (senza name, bypassa gli hidden)
	RANGE_PREVIEW.forEach(([rangeId, cssVar, transform]) => {
		const range = document.getElementById(
			rangeId,
		) as HTMLInputElement | null;
		range?.addEventListener("input", () =>
			previewSetVar(
				cssVar,
				transform ? transform(range.value) : range.value,
			),
		);
	});

	// Re-applica tutti i CSS vars dopo ogni reload dell'iframe
	// (intenzionale: gestisce navigazione interna e primo caricamento)
	previewFrame?.addEventListener("load", applyAllVarsToPreview);

	// ── VIEWPORT TOGGLE: Desktop / Tablet / Mobile ───────────────────────────
	const BTN_ACT = ["bg-indigo-50", "text-indigo-700", "border-indigo-300"];
	const BTN_INACT = ["text-gray-500"];

	const viewportBtns = {
		desktop: document.getElementById("btn-desktop"),
		tablet: document.getElementById("btn-tablet"),
		mobile: document.getElementById("btn-mobile"),
	} as Record<string, HTMLElement | null>;

	function setViewMode(mode: "desktop" | "tablet" | "mobile") {
		if (!previewWrapper) return;

		const sizes = {
			desktop: "width:100%;height:100%;",
			tablet: "width:768px;height:1024px;overflow:hidden;",
			mobile: "width:375px;height:812px;overflow:hidden;",
		};
		previewWrapper.style.cssText = sizes[mode];

		Object.entries(viewportBtns).forEach(([key, btn]) => {
			if (!btn) return;
			if (key === mode) {
				btn.classList.add(...BTN_ACT);
				btn.classList.remove(...BTN_INACT);
			} else {
				btn.classList.remove(...BTN_ACT);
				btn.classList.add(...BTN_INACT);
			}
		});
	}

	viewportBtns.desktop?.addEventListener("click", () =>
		setViewMode("desktop"),
	);
	viewportBtns.tablet?.addEventListener("click", () => setViewMode("tablet"));
	viewportBtns.mobile?.addEventListener("click", () => setViewMode("mobile"));

	// ── TIPOGRAFIA TOGGLE (homepage ↔ typography-test) ───────────────────────
	const btnTypo = document.getElementById("btn-typography");
	let typoActive = false;

	btnTypo?.addEventListener("click", () => {
		typoActive = !typoActive;
		if (previewFrame)
			previewFrame.src = typoActive ? "/admin/typography-test" : "/";
		btnTypo.classList.toggle("bg-indigo-50", typoActive);
		btnTypo.classList.toggle("text-indigo-700", typoActive);
		btnTypo.classList.toggle("border-indigo-300", typoActive);
		btnTypo.classList.toggle("text-gray-600", !typoActive);
		btnTypo.classList.toggle("border-gray-200", !typoActive);
	});

	// ── PREVIEW PANEL TOGGLE E RESIZE ────────────────────────────────────────
	const previewPanel = document.getElementById(
		"preview-panel",
	) as HTMLElement | null;
	const controlPanel = document.getElementById(
		"control-panel",
	) as HTMLElement | null;
	const resizeHandle = document.getElementById(
		"resize-handle",
	) as HTMLElement | null;

	let previewOpen = false;
	let sidebarWasOpen = true;

	// Mantiene traccia dell'ultimo stato sidebar (notificato da Sidebar.astro)
	document.addEventListener("admin:sidebarChanged", (e: Event) => {
		if (!previewOpen)
			sidebarWasOpen = (e as CustomEvent<{ open: boolean }>).detail.open;
	});

	function setPreview(open: boolean) {
		previewOpen = open;

		if (open) {
			previewPanel?.classList.remove("hidden");
			resizeHandle?.classList.remove("hidden");
			if (controlPanel)
				controlPanel.style.cssText = "width:380px;flex-shrink:0;";
			if (previewPanel)
				previewPanel.style.cssText = "flex:1;min-width:200px;";
			// Chiede alla sidebar di chiudersi per dare spazio al preview
			document.dispatchEvent(
				new CustomEvent("admin:setSidebar", {
					detail: { open: false },
				}),
			);
			// Applica i vars dopo che l'iframe si stabilizza (ritardo intenzionale)
			setTimeout(applyAllVarsToPreview, 200);
		} else {
			previewPanel?.classList.add("hidden");
			resizeHandle?.classList.add("hidden");
			if (controlPanel)
				controlPanel.style.cssText = "flex:1;min-width:0;";
			if (previewPanel) previewPanel.style.cssText = "";
			// Ripristina lo stato sidebar precedente all'apertura del preview
			document.dispatchEvent(
				new CustomEvent("admin:setSidebar", {
					detail: { open: sidebarWasOpen },
				}),
			);
		}

		const label = document.getElementById("preview-label");
		if (label) label.textContent = open ? "Chiudi Preview" : "Live Preview";
	}

	document
		.getElementById("btn-preview-toggle")
		?.addEventListener("click", () => setPreview(!previewOpen));
	document
		.getElementById("btn-close-preview")
		?.addEventListener("click", () => setPreview(false));
</script>
