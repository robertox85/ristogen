---
const { content } = Astro.props;
---

<section id="theme" class="tab-section">
	<div class="rounded-xl border border-gray-200 bg-white shadow-sm p-7">
		<h3 class="text-lg font-bold mb-6 text-gray-900">Theme</h3>
		<form id="form-theme" class="space-y-8">
			<!-- ── COLORI BRAND ─────────────────────────────── -->
			<div>
				<p
					class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4"
				>
					Colori Brand
				</p>
				<div
					class="grid gap-6"
					style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr))"
				>
					<div class="flex items-center gap-3">
						<input
							type="color"
							name="theme_primary"
							value={content.theme.primary}
							class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
						/>
						<div>
							<p class="text-sm font-medium text-gray-700">
								Colore Primario
							</p>
							<p class="text-xs text-gray-400">
								Pulsanti, accenti
							</p>
						</div>
					</div>
					<div class="flex items-center gap-3">
						<input
							type="color"
							name="theme_secondary"
							value={content.theme.secondary}
							class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
						/>
						<div>
							<p class="text-sm font-medium text-gray-700">
								Colore Secondario
							</p>
							<p class="text-xs text-gray-400">
								Elementi decorativi
							</p>
						</div>
					</div>
					<div class="flex items-center gap-3">
						<input
							type="color"
							name="theme_bg"
							value={content.theme.bg}
							class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
						/>
						<div>
							<p class="text-sm font-medium text-gray-700">
								Sfondo
							</p>
							<p class="text-xs text-gray-400">
								Colore di fondo pagina
							</p>
						</div>
					</div>
					<div class="flex items-center gap-3">
						<input
							type="color"
							name="theme_text"
							value={content.theme.text}
							class="w-10 h-10 p-0 border-none bg-transparent cursor-pointer rounded"
						/>
						<div>
							<p class="text-sm font-medium text-gray-700">
								Testo
							</p>
							<p class="text-xs text-gray-400">
								Colore testo principale
							</p>
						</div>
					</div>
				</div>
			</div>

			<!-- ── TIPOGRAFIA ────────────────────────────────── -->
			<div>
				<p
					class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4"
				>
					Tipografia
				</p>
				<div
					class="lg:grid gap-6"
					style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr))"
				>
					<!-- Font Heading card -->
					<div
						class="rounded-lg border border-gray-200 bg-gray-50 p-4"
					>
						<p class="text-sm font-semibold text-gray-700 mb-3">
							Font Titoli
						</p>
						<div class="lg:flex gap-4 mb-3">
							<label
								class="lg:flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
							>
								<input
									type="radio"
									name="font_heading_mode"
									value="standard"
									checked={!content.theme.customFonts
										?.heading}
								/>
								Standard
							</label>
							<label
								class="lg:flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
							>
								<input
									type="radio"
									name="font_heading_mode"
									value="custom"
									checked={!!content.theme.customFonts
										?.heading}
								/>
								Custom
							</label>
						</div>
						<div id="heading-standard-panel">
							<select
								name="theme_fontHeading"
								id="select-fontHeading"
								class="w-full px-3 py-2 rounded-md border border-gray-200 bg-white text-gray-900 text-sm"
							>
								<option
									value="'Playfair Display', serif"
									selected={content.theme.fontHeading ===
										"'Playfair Display', serif"}
									>Playfair Display</option
								>
								<option
									value="'Montserrat', sans-serif"
									selected={content.theme.fontHeading ===
										"'Montserrat', sans-serif"}
									>Montserrat</option
								>
								<option
									value="'Cormorant Garamond', serif"
									selected={content.theme.fontHeading ===
										"'Cormorant Garamond', serif"}
									>Cormorant Garamond</option
								>
								<option
									value="'Inter', sans-serif"
									selected={content.theme.fontHeading ===
										"'Inter', sans-serif"}>Inter</option
								>
								<option
									value="'Lora', serif"
									selected={content.theme.fontHeading ===
										"'Lora', serif"}>Lora</option
								>
								<option
									value="'Oswald', sans-serif"
									selected={content.theme.fontHeading ===
										"'Oswald', sans-serif"}>Oswald</option
								>
							</select>
						</div>
						<div id="heading-custom-panel" class="hidden">
							<input
								type="file"
								name="font_heading_file"
								accept=".ttf,.woff2"
								class="w-full text-sm text-gray-900"
							/>
							{
								content.theme.customFonts?.heading && (
									<p class="text-xs text-green-600 mt-1">
										Caricato:{" "}
										{content.theme.customFonts.heading}
										{content.theme.customFonts
											.headingType && (
											<span class="ml-1 px-1.5 py-0.5 rounded bg-green-100 text-green-700 font-mono">
												{
													content.theme.customFonts
														.headingType
												}
											</span>
										)}
									</p>
								)
							}
						</div>
						<!-- Peso -->
						<div class="mt-4">
							<p class="text-xs text-gray-500 mb-1">
								Peso carattere titoli
							</p>
							<div class="flex gap-2">
								{
									[
										["300", "Sottile"],
										["400", "Regolare"],
										["700", "Grassetto"],
										["900", "Extra Grassetto"],
									].map(([val, label]) => (
										<label class="flex-1 text-center cursor-pointer">
											<input
												type="radio"
												name="theme_fontWeightHeading"
												value={val}
												checked={
													content.theme
														.fontWeightHeading ===
														val ||
													(!content.theme
														.fontWeightHeading &&
														val === "700")
												}
												class="sr-only peer"
											/>
											<span class="block py-1.5 px-1 rounded-md border border-gray-200 text-xs text-gray-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 transition">
												{label}
											</span>
										</label>
									))
								}
							</div>
						</div>
						<!-- Interlinea -->
						<div class="mt-4">
							<div class="flex justify-between items-center mb-1">
								<p class="text-xs text-gray-500">
									Interlinea titoli
								</p>
								<span
									id="lh-heading-val"
									class="text-xs font-mono text-indigo-600"
									>{
										content.theme.lineHeightHeading ?? "1.2"
									}</span
								>
							</div>
							<input
								type="range"
								name="theme_lineHeightHeading"
								min="1"
								max="2"
								step="0.1"
								value={content.theme.lineHeightHeading ?? "1.2"}
								class="w-full accent-indigo-500"
								id="lh-heading-range"
							/>
						</div>
					</div>

					<!-- Font Body card -->
					<div
						class="rounded-lg border border-gray-200 bg-gray-50 p-4"
					>
						<p class="text-sm font-semibold text-gray-700 mb-3">
							Font Testo
						</p>
						<div class="flex gap-4 mb-3">
							<label
								class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
							>
								<input
									type="radio"
									name="font_body_mode"
									value="standard"
									checked={!content.theme.customFonts?.body}
								/>
								Standard
							</label>
							<label
								class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
							>
								<input
									type="radio"
									name="font_body_mode"
									value="custom"
									checked={!!content.theme.customFonts?.body}
								/>
								Custom
							</label>
						</div>
						<div id="body-standard-panel">
							<select
								name="theme_fontBody"
								id="select-fontBody"
								class="w-full px-3 py-2 rounded-md border border-gray-200 bg-white text-gray-900 text-sm"
							>
								<option
									value="'Playfair Display', serif"
									selected={content.theme.fontBody ===
										"'Playfair Display', serif"}
									>Playfair Display</option
								>
								<option
									value="'Montserrat', sans-serif"
									selected={content.theme.fontBody ===
										"'Montserrat', sans-serif"}
									>Montserrat</option
								>
								<option
									value="'Cormorant Garamond', serif"
									selected={content.theme.fontBody ===
										"'Cormorant Garamond', serif"}
									>Cormorant Garamond</option
								>
								<option
									value="'Inter', sans-serif"
									selected={content.theme.fontBody ===
										"'Inter', sans-serif"}>Inter</option
								>
								<option
									value="'Lora', serif"
									selected={content.theme.fontBody ===
										"'Lora', serif"}>Lora</option
								>
								<option
									value="'Oswald', sans-serif"
									selected={content.theme.fontBody ===
										"'Oswald', sans-serif"}>Oswald</option
								>
							</select>
						</div>
						<div id="body-custom-panel" class="hidden">
							<input
								type="file"
								name="font_body_file"
								accept=".ttf,.woff2"
								class="w-full text-sm text-gray-900"
							/>
							{
								content.theme.customFonts?.body && (
									<p class="text-xs text-green-600 mt-1">
										Caricato:{" "}
										{content.theme.customFonts.body}
										{content.theme.customFonts.bodyType && (
											<span class="ml-1 px-1.5 py-0.5 rounded bg-green-100 text-green-700 font-mono">
												{
													content.theme.customFonts
														.bodyType
												}
											</span>
										)}
									</p>
								)
							}
						</div>
						<!-- Peso -->
						<div class="mt-4">
							<p class="text-xs text-gray-500 mb-1">
								Peso carattere testo
							</p>
							<div class="flex gap-2">
								{
									[
										["300", "Sottile"],
										["400", "Regolare"],
										["700", "Grassetto"],
										["900", "Extra Grassetto"],
									].map(([val, label]) => (
										<label class="flex-1 text-center cursor-pointer">
											<input
												type="radio"
												name="theme_fontWeightBody"
												value={val}
												checked={
													content.theme
														.fontWeightBody ===
														val ||
													(!content.theme
														.fontWeightBody &&
														val === "400")
												}
												class="sr-only peer"
											/>
											<span class="block py-1.5 px-1 rounded-md border border-gray-200 text-xs text-gray-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 transition">
												{label}
											</span>
										</label>
									))
								}
							</div>
						</div>
						<!-- Interlinea -->
						<div class="mt-4">
							<div class="flex justify-between items-center mb-1">
								<p class="text-xs text-gray-500">
									Interlinea testo
								</p>
								<span
									id="lh-body-val"
									class="text-xs font-mono text-indigo-600"
									>{
										content.theme.lineHeightBody ?? "1.6"
									}</span
								>
							</div>
							<input
								type="range"
								name="theme_lineHeightBody"
								min="1"
								max="2.5"
								step="0.1"
								value={content.theme.lineHeightBody ?? "1.6"}
								class="w-full accent-indigo-500"
								id="lh-body-range"
							/>
						</div>
					</div>
				</div>

				<!-- Dimensione base font -->
				<div class="mt-4">
					<div class="flex justify-between items-center mb-1">
						<p class="text-sm font-medium text-gray-700">
							Dimensione testo base
						</p>
						<span
							id="fs-base-val"
							class="text-xs font-mono text-indigo-600"
							>{content.theme.fontSizeBase ?? "1rem"}</span
						>
					</div>
					<input
						type="range"
						id="fs-base-range"
						name="theme_fontSizeBase_px"
						min="14"
						max="22"
						step="1"
						value={parseInt(
							(content.theme.fontSizeBase ?? "16px").replace(
								/[^0-9]/g,
								"",
							),
						) || 16}
						class="w-full accent-indigo-500"
					/>
					<input
						type="hidden"
						name="theme_fontSizeBase"
						id="fs-base-hidden"
						value={content.theme.fontSizeBase ?? "1rem"}
					/>
					<div
						class="flex justify-between text-xs text-gray-400 mt-1"
					>
						<span>Piccolo (14px)</span><span>Grande (22px)</span>
					</div>
				</div>

				<!-- Allineamento testo -->
				<div class="mt-4">
					<p class="text-sm font-medium text-gray-700 mb-2">
						Allineamento testo
					</p>
					<div class="flex gap-2">
						{
							[
								["left", "← Sinistra"],
								["center", "⊜ Centro"],
								["right", "Destra →"],
							].map(([val, label]) => (
								<label class="flex-1 text-center cursor-pointer">
									<input
										type="radio"
										name="theme_textAlign"
										value={val}
										checked={
											content.theme.textAlign === val ||
											(!content.theme.textAlign &&
												val === "left")
										}
										class="sr-only peer"
									/>
									<span class="block py-2 rounded-md border border-gray-200 text-sm text-gray-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 transition">
										{label}
									</span>
								</label>
							))
						}
					</div>
				</div>
			</div>

			<!-- ── GERARCHIA TITOLI ───────────────────────── -->
			<div>
				<p
					class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4"
				>
					Gerarchia Titoli
				</p>
				<div class="space-y-4">
					<!-- H1 Impatto Hero -->
					<div
						class="rounded-lg border border-gray-200 bg-gray-50 p-4"
					>
						<p class="text-sm font-semibold text-gray-700">
							H1 — Impatto Hero
						</p>
						<p class="text-xs text-gray-400 mb-3">
							Titolo principale della sezione hero
						</p>
						<div
							class="grid gap-4"
							style="grid-template-columns:repeat(auto-fit,minmax(160px,1fr))"
						>
							<div>
								<div
									class="flex justify-between items-center mb-1"
								>
									<p class="text-xs text-gray-500">
										Dimensione
									</p>
									<span
										id="fsh1-val"
										class="text-xs font-mono text-indigo-600"
										>{content.theme.fsH1 ?? "4rem"}</span
									>
								</div>
								<input
									type="range"
									id="fsh1-range"
									name="theme_fsH1_raw"
									min="2.5"
									max="6"
									step="0.25"
									value={parseFloat(
										(content.theme.fsH1 ?? "4rem").replace(
											"rem",
											"",
										),
									) || 4}
									class="w-full accent-indigo-500"
								/>
								<input
									type="hidden"
									name="theme_fsH1"
									id="fsh1-hidden"
									value={content.theme.fsH1 ?? "4rem"}
								/>
								<div
									class="flex justify-between text-xs text-gray-400 mt-0.5"
								>
									<span>2.5rem</span><span>6rem</span>
								</div>
							</div>
							<div>
								<div
									class="flex justify-between items-center mb-1"
								>
									<p class="text-xs text-gray-500">
										Compressione Mobile
									</p>
									<span
										id="mob-h1-val"
										class="text-xs font-mono text-indigo-600"
										>{
											content.theme.mobileScaleH1 ?? "65"
										}%</span
									>
								</div>
								<input
									type="range"
									id="mob-h1-range"
									name="theme_mobileScaleH1"
									min="40"
									max="100"
									step="5"
									value={content.theme.mobileScaleH1 ?? "65"}
									class="w-full accent-indigo-500"
								/>
								<div
									class="flex justify-between text-xs text-gray-400 mt-0.5"
								>
									<span>40%</span><span>100%</span>
								</div>
							</div>
						</div>
						<div class="mt-3">
							<div class="flex justify-between items-center mb-1">
								<p class="text-xs text-gray-500">
									Crenatura (Letter Spacing)
								</p>
								<span
									id="lsh1-val"
									class="text-xs font-mono text-indigo-600"
									>{
										content.theme.letterSpacingH1 ?? "0em"
									}</span
								>
							</div>
							<input
								type="range"
								id="lsh1-range"
								name="theme_letterSpacingH1_raw"
								min="-5"
								max="20"
								step="1"
								value={Math.round(
									parseFloat(
										(
											content.theme.letterSpacingH1 ??
											"0em"
										).replace("em", ""),
									) * 100,
								) || 0}
								class="w-full accent-indigo-500"
							/>
							<input
								type="hidden"
								name="theme_letterSpacingH1"
								id="lsh1-hidden"
								value={content.theme.letterSpacingH1 ?? "0em"}
							/>
							<div
								class="flex justify-between text-xs text-gray-400 mt-0.5"
							>
								<span>-0.05em (stretto)</span><span
									>0.2em (ariosa)</span
								>
							</div>
						</div>
					</div>

					<!-- H2 Titoli Sezione -->
					<div
						class="rounded-lg border border-gray-200 bg-gray-50 p-4"
					>
						<p class="text-sm font-semibold text-gray-700">
							H2 — Titoli Sezione
						</p>
						<p class="text-xs text-gray-400 mb-3">
							About, Gallery, Contatti
						</p>
						<div
							class="grid gap-4"
							style="grid-template-columns:repeat(auto-fit,minmax(160px,1fr))"
						>
							<div>
								<div
									class="flex justify-between items-center mb-1"
								>
									<p class="text-xs text-gray-500">
										Dimensione
									</p>
									<span
										id="fsh2-val"
										class="text-xs font-mono text-indigo-600"
										>{content.theme.fsH2 ?? "2.5rem"}</span
									>
								</div>
								<input
									type="range"
									id="fsh2-range"
									name="theme_fsH2_raw"
									min="1.5"
									max="3.5"
									step="0.25"
									value={parseFloat(
										(
											content.theme.fsH2 ?? "2.5rem"
										).replace("rem", ""),
									) || 2.5}
									class="w-full accent-indigo-500"
								/>
								<input
									type="hidden"
									name="theme_fsH2"
									id="fsh2-hidden"
									value={content.theme.fsH2 ?? "2.5rem"}
								/>
								<div
									class="flex justify-between text-xs text-gray-400 mt-0.5"
								>
									<span>1.5rem</span><span>3.5rem</span>
								</div>
							</div>
							<div>
								<div
									class="flex justify-between items-center mb-1"
								>
									<p class="text-xs text-gray-500">
										Compressione Mobile
									</p>
									<span
										id="mob-h2-val"
										class="text-xs font-mono text-indigo-600"
										>{
											content.theme.mobileScaleH2 ?? "80"
										}%</span
									>
								</div>
								<input
									type="range"
									id="mob-h2-range"
									name="theme_mobileScaleH2"
									min="50"
									max="100"
									step="5"
									value={content.theme.mobileScaleH2 ?? "80"}
									class="w-full accent-indigo-500"
								/>
								<div
									class="flex justify-between text-xs text-gray-400 mt-0.5"
								>
									<span>50%</span><span>100%</span>
								</div>
							</div>
						</div>
						<div class="mt-3">
							<div class="flex justify-between items-center mb-1">
								<p class="text-xs text-gray-500">
									Crenatura (Letter Spacing)
								</p>
								<span
									id="lsh2-val"
									class="text-xs font-mono text-indigo-600"
									>{
										content.theme.letterSpacingH2 ?? "0em"
									}</span
								>
							</div>
							<input
								type="range"
								id="lsh2-range"
								name="theme_letterSpacingH2_raw"
								min="-5"
								max="20"
								step="1"
								value={Math.round(
									parseFloat(
										(
											content.theme.letterSpacingH2 ??
											"0em"
										).replace("em", ""),
									) * 100,
								) || 0}
								class="w-full accent-indigo-500"
							/>
							<input
								type="hidden"
								name="theme_letterSpacingH2"
								id="lsh2-hidden"
								value={content.theme.letterSpacingH2 ?? "0em"}
							/>
							<div
								class="flex justify-between text-xs text-gray-400 mt-0.5"
							>
								<span>-0.05em (stretto)</span><span
									>0.2em (ariosa)</span
								>
							</div>
						</div>
					</div>

					<!-- H3 Sottotitoli -->
					<div
						class="rounded-lg border border-gray-200 bg-gray-50 p-4"
					>
						<p class="text-sm font-semibold text-gray-700">
							H3 — Sottotitoli
