---
export const prerender = false;
import ThemeColors from "./theme/ThemeColors.astro";
import ThemeTypography from "./theme/ThemeTypography.astro";
import ThemeTitles from "./theme/ThemeTitles.astro";
import ThemeSpacing from "./theme/ThemeSpacing.astro";
const { content } = Astro.props;
---

<section id="theme" class="tab-section">
	<div class="rounded-xl border border-gray-200 bg-white shadow-sm p-7">
		<h3 class="text-lg font-bold mb-6 text-gray-900">Theme</h3>
		<form id="form-theme" class="space-y-8">
			<ThemeColors theme={content.theme} />

			<ThemeTypography theme={content.theme} />

			<ThemeTitles theme={content.theme} />

			<ThemeSpacing theme={content.theme} />

			<button
				type="submit"
				class="w-full py-2 rounded-md bg-indigo-500 hover:bg-indigo-600 font-semibold text-white transition"
			>
				Salva
			</button>
		</form>
	</div>
</section>
