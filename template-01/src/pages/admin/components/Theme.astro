						<div class="flex justify-between items-center mb-1">
							<p class="text-xs text-gray-500">Dimensione</p>
							<span
								id="fsh3-val"
								class="text-xs font-mono text-indigo-600"
								>{content.theme.fsH3 ?? "1.75rem"}</span
							>
						</div>
						<input
							type="range"
							id="fsh3-range"
							name="theme_fsH3_raw"
							min="1"
							max="2.5"
							step="0.25"
							value={parseFloat(
								(content.theme.fsH3 ?? "1.75rem").replace(
									"rem",
									"",
								),
							) || 1.75}
							class="w-full accent-indigo-500"
						/>
						<input
							type="hidden"
							name="theme_fsH3"
							id="fsh3-hidden"
							value={content.theme.fsH3 ?? "1.75rem"}
						/>
						<div
							class="flex justify-between text-xs text-gray-400 mt-0.5"
						>
							<span>1rem</span><span>2.5rem</span>
						</div>
					</div>
				</div>
			</div>

			<!-- ── SPAZI E BORDI ───────────────────────────── -->
			<div>
				<p
					class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4"
				>
					Spazi e Bordi
				</p>
				<div class="space-y-5">
					<!-- Section Padding -->
					<div>
						<div class="flex justify-between items-center mb-1">
							<div>
								<p class="text-sm font-medium text-gray-700">
									Respiro delle sezioni
								</p>
								<p class="text-xs text-gray-400">
									Spazio verticale sopra/sotto ogni sezione
								</p>
							</div>
							<span
								id="sp-val"
								class="text-xs font-mono text-indigo-600"
								>{content.theme.sectionPadding ?? "6rem"}</span
							>
						</div>
						<input
							type="range"
							id="sp-range"
							name="theme_sectionPadding_raw"
							min="2"
							max="10"
							step="0.5"
							value={parseFloat(
								(
									content.theme.sectionPadding ?? "6rem"
								).replace("rem", ""),
							) || 6}
							class="w-full accent-indigo-500"
						/>
						<input
							type="hidden"
							name="theme_sectionPadding"
							id="sp-hidden"
							value={content.theme.sectionPadding ?? "6rem"}
						/>
						<div
							class="flex justify-between text-xs text-gray-400 mt-1"
						>
							<span>Compatto (2rem)</span><span
								>Arioso (10rem)</span
							>
						</div>
					</div>
					<!-- Spacing -->
					<div>
						<div class="flex justify-between items-center mb-1">
							<div>
								<p class="text-sm font-medium text-gray-700">
									Distanza tra elementi
								</p>
								<p class="text-xs text-gray-400">
									Margine interno tra blocchi di contenuto
								</p>
							</div>
							<span
								id="spc-val"
								class="text-xs font-mono text-indigo-600"
								>{content.theme.spacing ?? "1.5rem"}</span
							>
						</div>
						<input
							type="range"
							id="spc-range"
							name="theme_spacing_raw"
							min="0.5"
							max="4"
							step="0.25"
							value={parseFloat(
								(content.theme.spacing ?? "1.5rem").replace(
									"rem",
									"",
								),
							) || 1.5}
							class="w-full accent-indigo-500"
						/>
						<input
							type="hidden"
							name="theme_spacing"
							id="spc-hidden"
							value={content.theme.spacing ?? "1.5rem"}
						/>
						<div
							class="flex justify-between text-xs text-gray-400 mt-1"
						>
							<span>Stretto (0.5rem)</span><span
								>Ampio (4rem)</span
							>
						</div>
					</div>
					<!-- Border Radius -->
					<div>
						<div class="flex justify-between items-center mb-1">
							<div>
								<p class="text-sm font-medium text-gray-700">
									Arrotondamento angoli
								</p>
								<p class="text-xs text-gray-400">
									Bordi di card e pulsanti
								</p>
							</div>
							<span
								id="radius-val"
								class="text-xs font-mono text-indigo-600"
								>{content.theme.radius}</span
							>
						</div>
						<input
							type="range"
							id="radius-range"
							name="theme_radius_raw"
							min="0"
							max="32"
							step="2"
							value={parseInt(
								(content.theme.radius ?? "8px").replace(
									/[^0-9]/g,
									"",
								),
							) || 8}
							class="w-full accent-indigo-500"
						/>
						<input
							type="hidden"
							name="theme_radius"
							id="radius-hidden"
							value={content.theme.radius}
						/>
						<div
							class="flex justify-between text-xs text-gray-400 mt-1"
						>
							<span>Squadrato (0px)</span><span
								>Molto tondo (32px)</span
							>
						</div>
					</div>
				</div>
			</div>

			<button
				type="submit"
				class="w-full py-2 rounded-md bg-indigo-500 hover:bg-indigo-600 font-semibold text-white transition"
