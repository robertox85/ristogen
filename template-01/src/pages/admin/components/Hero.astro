---
export const prerender = false;
const { content } = Astro.props;
---

<section id="hero" class="tab-section hidden">
	<div class="rounded-xl border border-gray-200 bg-white shadow-sm p-7">
		<h3 class="text-lg font-bold mb-6 text-gray-900">Hero</h3>
		<form id="form-hero" class="space-y-6">
			<!-- Immagine hero: drag & drop con anteprima -->
			<div
				class="dropzone group relative border-2 border-dashed rounded-xl overflow-hidden cursor-pointer transition-colors border-gray-200 hover:border-indigo-400"
				data-dropzone="image"
			>
				<input
					type="file"
					name="hero_image"
					accept="image/*"
					class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
				/>
				<div
					class:list={[
						"dz-empty flex flex-col items-center gap-2 py-8 px-4 text-center",
						{ hidden: content.sections.hero.hero_image },
					]}
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="w-8 h-8 text-gray-400"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="1.5"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"
						></path>
					</svg>
					<p class="text-sm text-gray-500">
						Trascina un'immagine o <span
							class="font-medium text-indigo-600">sfoglia</span>
					</p>
					<p class="text-xs text-gray-400">PNG · JPG · WebP</p>
				</div>
				<div
					class:list={[
						"dz-filled relative",
						{ hidden: !content.sections.hero.hero_image },
					]}
				>
					<img
						class="dz-thumb w-full max-h-52 object-cover"
						src={content.sections.hero.hero_image || ""}
						alt="Anteprima immagine"
					/>
					<div
						class="absolute inset-0 flex items-center justify-center bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"
					>
						<span class="text-white text-sm font-semibold"
							>Cambia immagine</span
						>
					</div>
				</div>
			</div>
			<input
				type="text"
				name="hero_title"
				value={content.sections.hero.hero_title}
				placeholder="Titolo"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<input
				type="text"
				name="hero_message"
				value={content.sections.hero.hero_message}
				placeholder="Messaggio"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<input
				type="text"
				name="hero_cta"
				value={content.sections.hero.hero_cta}
				placeholder="CTA"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<button
				type="submit"
				class="w-full py-2 rounded-md bg-indigo-500 hover:bg-indigo-600 font-semibold text-white transition"
				>Salva</button
			>
		</form>
	</div>
</section>
