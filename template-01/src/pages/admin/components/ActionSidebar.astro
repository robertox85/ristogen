---

---

<aside
	id="action-sidebar"
	class="w-80 shrink-0 bg-gray-50 border-l border-gray-200 flex flex-col overflow-y-auto"
>
	<!-- ── DRAFT RESTORE BANNER ────────────────────────────────────────────── -->
	<div
		id="draft-banner"
		class="hidden mx-3 mt-3 p-3 bg-amber-50 border border-amber-200 rounded-xl text-sm"
	>
		<div class="flex items-start gap-2 mb-2">
			<svg
				class="w-4 h-4 text-amber-500 mt-0.5 shrink-0"
				fill="none"
				viewBox="0 0 24 24"
				stroke="currentColor"
				stroke-width="2"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
				></path>
			</svg>
			<div>
				<p class="text-amber-900 font-semibold text-xs">
					Modifiche non pubblicate
				</p>
				<p class="text-amber-700 text-xs mt-0.5">
					Vuoi ripristinare la bozza salvata?
				</p>
			</div>
		</div>
		<div class="flex gap-2">
			<button
				id="btn-restore-draft"
				class="flex-1 px-3 py-1.5 bg-amber-500 hover:bg-amber-600 text-white text-xs font-medium rounded-lg transition-colors"
			>
				Ripristina
			</button>
			<button
				id="btn-discard-draft"
				class="flex-1 px-3 py-1.5 bg-white hover:bg-gray-50 text-amber-800 text-xs font-medium rounded-lg border border-amber-300 transition-colors"
			>
				Ignora
			</button>
		</div>
	</div>

	<!-- ── PUBLISH CARD ────────────────────────────────────────────────────── -->
	<div class="p-3">
		<div
			class="bg-white rounded-xl border border-gray-200 p-4 flex flex-col gap-3 shadow-sm"
		>
			<!-- Status badge -->
			<div class="flex items-center justify-between">
				<div class="flex items-center gap-2">
					<span
						id="publish-status-dot"
						class="w-2 h-2 rounded-full bg-green-400"></span>
					<span
						id="publish-status-text"
						class="text-xs font-medium text-gray-600"
					>
						Sincronizzato
					</span>
				</div>
				<span
					id="last-saved-text"
					class="hidden text-xs text-gray-400 italic"></span>
			</div>

			<!-- Pubblica -->
			<button
				id="btn-publish"
				class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white text-sm font-semibold rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
			>
				<svg
					class="shrink-0 w-4 h-4"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"
					></path>
				</svg>
				<span id="btn-publish-label">Pubblica su GitHub</span>
			</button>

			<!-- Salva Bozza -->
			<button
				id="btn-save-draft"
				class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-white hover:bg-gray-50 text-gray-700 text-sm font-medium rounded-lg transition-colors border border-gray-200"
			>
				<svg
					class="shrink-0 w-4 h-4"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"
					></path>
				</svg>
				Salva Bozza
			</button>
		</div>
	</div>

	<!-- ── REVISION HISTORY ────────────────────────────────────────────────── -->
	<div class="px-3 pb-3">
		<div
			class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden"
		>
			<div
				class="flex items-center justify-between px-4 py-3 border-b border-gray-100"
			>
				<h3
					class="text-xs font-semibold text-gray-500 uppercase tracking-wider"
				>
					Revisioni
				</h3>
				<button
					id="btn-refresh-revisions"
					class="text-gray-400 hover:text-indigo-500 transition-colors"
					title="Aggiorna revisioni"
				>
					<svg
						class="w-3.5 h-3.5"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="2"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
						></path>
					</svg>
				</button>
			</div>
			<ul id="revisions-list" class="divide-y divide-gray-50">
				<li class="px-4 py-3 text-xs text-gray-400 italic">
					Caricamento…
				</li>
			</ul>
		</div>
	</div>

	<!-- ── SESSION INFO ────────────────────────────────────────────────────── -->
	<div class="px-3 pb-3">
		<div
			class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm flex flex-col gap-2.5"
		>
			<h3
				class="text-xs font-semibold text-gray-500 uppercase tracking-wider"
			>
				Sessione
			</h3>
			<div class="flex items-center justify-between text-xs">
				<span class="text-gray-500">Ultima modifica</span>
				<span id="session-last-edit" class="text-gray-700 font-medium"
					>—</span
				>
			</div>
			<div class="flex items-center justify-between text-xs">
				<span class="text-gray-500">Stato campi</span>
				<span
					id="session-validity"
					class="inline-flex items-center gap-1 text-green-600 font-medium"
				>
					<svg
						class="w-3 h-3"
						fill="currentColor"
						viewBox="0 0 20 20"
					>
						<path
							fill-rule="evenodd"
							d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
							clip-rule="evenodd"></path>
					</svg>
					Validi
				</span>
			</div>
		</div>
	</div>
</aside>

<script>
	const DRAFT_KEY = "ristogen_draft";

	// ── UTILITIES ─────────────────────────────────────────────────────────────

	function timeAgo(dateStr: string): string {
		const diffMs = Date.now() - new Date(dateStr).getTime();
		const diffMin = Math.floor(diffMs / 60_000);
		const diffH = Math.floor(diffMin / 60);
		const diffD = Math.floor(diffH / 24);
		if (diffMin < 2) return "Adesso";
		if (diffMin < 60) return `${diffMin} min fa`;
		if (diffH < 24) return `${diffH}h fa`;
		if (diffD === 1) return "Ieri";
		if (diffD < 7) return `${diffD} giorni fa`;
		return new Date(dateStr).toLocaleDateString("it-IT", {
			day: "numeric",
			month: "short",
		});
	}

	function escapeHtml(str: string): string {
		return str
			.replace(/&/g, "&amp;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;");
	}

	// ── STATUS ────────────────────────────────────────────────────────────────

	function setStatus(state: "synced" | "dirty" | "loading") {
		const dot = document.getElementById("publish-status-dot");
		const text = document.getElementById("publish-status-text");
		if (!dot || !text) return;
		const map = {
			synced: { color: "bg-green-400", label: "Sincronizzato" },
			dirty: { color: "bg-amber-400", label: "Modifiche non salvate" },
			loading: {
				color: "bg-blue-400 animate-pulse",
				label: "Deploy in corso…",
			},
		};
		const s = map[state];
		dot.className = `w-2 h-2 rounded-full ${s.color}`;
		text.textContent = s.label;
	}

	// ── DRAFT ─────────────────────────────────────────────────────────────────

	function serializeAllForms(): Record<string, string> {
		const data: Record<string, string> = {};
		document.querySelectorAll<HTMLFormElement>("form").forEach((form) => {
			form.querySelectorAll<
				HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement
			>(
				'input:not([type="file"]):not([type="submit"]):not([type="button"]), textarea, select',
			).forEach((el) => {
				if (!el.name) return;
				if (
					el instanceof HTMLInputElement &&
					(el.type === "checkbox" || el.type === "radio")
				) {
					if (el.checked) data[el.name] = el.value;
				} else {
					data[el.name] = (
						el as
							| HTMLInputElement
							| HTMLTextAreaElement
							| HTMLSelectElement
					).value;
				}
			});
		});
		return data;
	}

	function loadDraft(): {
		savedAt: string;
		fields: Record<string, string>;
	} | null {
		try {
			const raw = localStorage.getItem(DRAFT_KEY);
			return raw ? JSON.parse(raw) : null;
		} catch {
			return null;
		}
	}

	function clearDraft() {
		localStorage.removeItem(DRAFT_KEY);
		setStatus("synced");
		document.getElementById("draft-banner")?.classList.add("hidden");
		const lastSaved = document.getElementById("last-saved-text");
		if (lastSaved) lastSaved.classList.add("hidden");
	}

	function updateLastSavedText(isoDate: string) {
		const el = document.getElementById("last-saved-text");
		if (!el) return;
		el.textContent = `Bozza: ${timeAgo(isoDate)}`;
		el.classList.remove("hidden");
	}

	function saveDraft() {
		const payload = {
			savedAt: new Date().toISOString(),
			fields: serializeAllForms(),
		};
		localStorage.setItem(DRAFT_KEY, JSON.stringify(payload));
		updateLastSavedText(payload.savedAt);
		setStatus("dirty");
		// Flash feedback sul pulsante
		const btn = document.getElementById("btn-save-draft");
		if (btn) {
			const orig = btn.innerHTML;
			btn.innerHTML =
				'<svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span>Bozza salvata</span>';
			setTimeout(() => {
				btn.innerHTML = orig;
			}, 1800);
		}
	}

	function restoreDraft(fields: Record<string, string>) {
		Object.entries(fields).forEach(([name, value]) => {
			// Caso speciale: Quill gestisce il proprio stato interno,
			// dangerouslyPasteHTML aggiorna l'editor visivo e il listener
			// text-change sincronizza automaticamente l'input nascosto.
			if (name === "about_text") {
				const quill = (window as any).__quillAbout;
				if (quill) {
					quill.clipboard.dangerouslyPasteHTML(value);
				}
				return;
			}
			const el = document.querySelector<
				HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement
			>(`[name="${CSS.escape(name)}"]`);
			if (!el) return;
			if (
				el instanceof HTMLInputElement &&
				(el.type === "checkbox" || el.type === "radio")
			) {
				el.checked = el.value === value;
			} else {
				(
					el as
						| HTMLInputElement
						| HTMLTextAreaElement
						| HTMLSelectElement
				).value = value;
				el.dispatchEvent(new Event("input", { bubbles: true }));
				el.dispatchEvent(new Event("change", { bubbles: true }));
			}
		});
		setStatus("dirty");
		document.getElementById("draft-banner")?.classList.add("hidden");
	}

	// ── INIT: mostra banner se esiste una bozza ────────────────────────────────

	const draft = loadDraft();
	if (draft) {
		updateLastSavedText(draft.savedAt);
		setStatus("dirty");
		document.getElementById("draft-banner")?.classList.remove("hidden");
	}

	document
		.getElementById("btn-restore-draft")
		?.addEventListener("click", () => {
			const d = loadDraft();
			if (d) restoreDraft(d.fields);
		});

	document
		.getElementById("btn-discard-draft")
		?.addEventListener("click", clearDraft);

	// ── REVISION HISTORY ──────────────────────────────────────────────────────

	async function loadRevisions() {
		const list = document.getElementById("revisions-list");
		if (!list) return;
		list.innerHTML =
			'<li class="px-4 py-3 text-xs text-gray-400 italic">Caricamento…</li>';
		try {
			const res = await fetch("/admin/api/commits");
			if (!res.ok) throw new Error("HTTP " + res.status);
			const commits: {
				sha: string;
				message: string;
				date: string;
				author: string;
			}[] = await res.json();
			list.innerHTML =
				commits.length === 0
					? '<li class="px-4 py-3 text-xs text-gray-400 italic">Nessun commit trovato</li>'
					: commits
							.map(
								(c) => `
					<li class="px-4 py-3 flex flex-col gap-0.5 hover:bg-gray-50 transition-colors">
						<span class="text-xs font-medium text-gray-800 line-clamp-2">${escapeHtml(c.message)}</span>
						<span class="text-xs text-gray-400 flex items-center gap-1 mt-0.5">
							<svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" d="M12 6v6l4 2"/></svg>
							${escapeHtml(timeAgo(c.date))}
							<span class="text-gray-300">·</span>
							<code class="font-mono text-indigo-400">${escapeHtml(c.sha)}</code>
						</span>
					</li>`,
							)
							.join("");
		} catch {
			list.innerHTML =
				'<li class="px-4 py-3 text-xs text-red-400">Errore caricamento revisioni</li>';
		}
	}

	loadRevisions();
	document
		.getElementById("btn-refresh-revisions")
		?.addEventListener("click", loadRevisions);

	// ── PUBLISH BUTTON ────────────────────────────────────────────────────────

	const PUBLISH_BTN_CONTENT =
		'<svg class="shrink-0 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg><span id="btn-publish-label">Pubblica su GitHub</span>';
	const SPINNER_BTN_CONTENT =
		'<svg class="animate-spin shrink-0 w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg><span>Deploy in corso…</span>';

	document.getElementById("btn-publish")?.addEventListener("click", () => {
		document.dispatchEvent(new CustomEvent("ristogen:publish"));
	});

	document
		.getElementById("btn-save-draft")
		?.addEventListener("click", saveDraft);

	// Permette alla FAB nella preview di triggerare il salvataggio bozza
	document.addEventListener("ristogen:save-draft", saveDraft);

	// ── SESSION INFO: traccia ultima modifica ─────────────────────────────────

	let autoSaveTimer: ReturnType<typeof setTimeout> | null = null;

	document.addEventListener("input", () => {
		setStatus("dirty");
		const now = new Date().toLocaleTimeString("it-IT", {
			hour: "2-digit",
			minute: "2-digit",
		});
		const el = document.getElementById("session-last-edit");
		if (el) el.textContent = now;
		// Auto-salva bozza dopo 30s di inattività
		if (autoSaveTimer) clearTimeout(autoSaveTimer);
		autoSaveTimer = setTimeout(saveDraft, 30_000);
	});

	window.addEventListener("beforeunload", () => {
		if (autoSaveTimer) clearTimeout(autoSaveTimer);
	});
	// ── GLOBAL EVENTS (da index.astro) ────────────────────────────────────────

	document.addEventListener("ristogen:publishing", () => {
		const btn = document.getElementById(
			"btn-publish",
		) as HTMLButtonElement | null;
		if (btn) {
			btn.disabled = true;
			btn.innerHTML = SPINNER_BTN_CONTENT;
		}
		setStatus("loading");
	});

	document.addEventListener("ristogen:saved", () => {
		const btn = document.getElementById(
			"btn-publish",
		) as HTMLButtonElement | null;
		if (btn) {
			btn.disabled = false;
			btn.innerHTML = PUBLISH_BTN_CONTENT;
		}
		clearDraft();
		loadRevisions();
		setStatus("synced");
	});

	document.addEventListener("ristogen:save-error", () => {
		const btn = document.getElementById(
			"btn-publish",
		) as HTMLButtonElement | null;
		if (btn) {
			btn.disabled = false;
			btn.innerHTML = PUBLISH_BTN_CONTENT;
		}
		setStatus("dirty");
	});
</script>
