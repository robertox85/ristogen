---
export const prerender = false;
const { content } = Astro.props;
---

<section id="footer" class="tab-section hidden">
	<div class="rounded-xl border border-gray-200 bg-white shadow-sm p-7">
		<h3 class="text-lg font-bold mb-6 text-gray-900">Footer</h3>
		<form id="form-footer" class="space-y-6">
			<input
				type="text"
				name="footer_name"
				value={content.sections.footer.footer_name}
				placeholder="Nome"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<input
				type="text"
				name="footer_copy"
				value={content.sections.footer.footer_copy}
				placeholder="Copyright"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<input
				type="text"
				name="footer_instagram"
				value={content.sections.footer.socials.footer_instagram}
				placeholder="Instagram"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<input
				type="text"
				name="footer_facebook"
				value={content.sections.footer.socials.footer_facebook}
				placeholder="Facebook"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			{/* Footer: preview social, logo, se previsti in futuro */}
			{
				content.sections.footer.socials.footer_instagram && (
					<a
						href={content.sections.footer.socials.footer_instagram}
						target="_blank"
						rel="noopener"
						class="block mb-2 text-indigo-600 underline"
					>
						Instagram attuale
					</a>
				)
			}
			{
				content.sections.footer.socials.footer_facebook && (
					<a
						href={content.sections.footer.socials.footer_facebook}
						target="_blank"
						rel="noopener"
						class="block mb-2 text-indigo-600 underline"
					>
						Facebook attuale
					</a>
				)
			}
			<button
				type="submit"
				class="w-full py-2 rounded-md bg-indigo-500 hover:bg-indigo-600 font-semibold text-white transition"
				>Salva</button
			>
		</form>
	</div>
</section>
