---
import gfontsRaw from "../../data/google-fonts-cache.json";
const { theme } = Astro.props;

type GFont = { f: string; c: string; v: string[]; last: string };
const genericMap: Record<string, string> = {
	serif: "serif",
	"sans-serif": "sans-serif",
	display: "cursive",
	handwriting: "cursive",
	monospace: "monospace",
};
const fontOptions = (gfontsRaw as GFont[]).map((font) => ({
	value: `'${font.f}', ${genericMap[font.c] ?? "sans-serif"}`,
	label: font.f,
}));

// Valori iniziali per il server-render del label visibile nel trigger
const headingValue = theme.fontHeading ?? fontOptions[0]?.value ?? "";
const headingLabel =
	fontOptions.find((f) => f.value === headingValue)?.label ??
	headingValue.replace(/'([^']+)'.*/, "$1");
const bodyValue = theme.fontBody ?? fontOptions[0]?.value ?? "";
const bodyLabel =
	fontOptions.find((f) => f.value === bodyValue)?.label ??
	bodyValue.replace(/'([^']+)'.*/, "$1");
---

<div>
	<p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">
		Tipografia
	</p>
	<div
		class="grid gap-6"
		style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr))"
	>
		<!-- Font Heading card -->
		<div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
			<p class="text-sm font-semibold text-gray-700 mb-3">Font Titoli</p>
			<div class="flex gap-4 mb-3">
				<label
					class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
				>
					<input
						type="radio"
						name="font_heading_mode"
						value="standard"
						checked={!theme.customFonts?.heading}
					/>
					Standard
				</label>
				<label
					class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
				>
					<input
						type="radio"
						name="font_heading_mode"
						value="custom"
						checked={!!theme.customFonts?.heading}
					/>
					Custom
				</label>
			</div>
			<div id="heading-standard-panel" class="relative">
				<input
					type="hidden"
					name="theme_fontHeading"
					id="hidden-font-heading"
					value={headingValue}
				/>
				<button
					type="button"
					id="heading-picker-trigger"
					class="w-full flex items-center justify-between gap-2 px-3 py-2 rounded-md border border-gray-200 bg-white text-gray-900 text-sm hover:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-300 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
				>
					<span id="heading-picker-label" class="truncate"
						>{headingLabel}</span
					>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-4 w-4 shrink-0 text-gray-400"
						viewBox="0 0 20 20"
						fill="currentColor"
					>
						<path
							fill-rule="evenodd"
							d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
							clip-rule="evenodd"></path>
					</svg>
				</button>
				<div
					id="heading-picker-panel"
					class="hidden absolute z-50 left-0 mt-1 rounded-md border border-gray-200 bg-white shadow-lg"
					style="min-width:220px"
				>
					<div class="p-2 border-b border-gray-100">
						<input
							type="text"
							id="heading-picker-search"
							placeholder="Cerca font…"
							autocomplete="off"
							class="w-full px-2 py-1.5 text-sm border border-gray-200 rounded focus:outline-none focus:ring-1 focus:ring-indigo-300"
						/>
					</div>
					<ul
						id="heading-picker-list"
						class="overflow-y-auto max-h-52 py-1"
					>
					</ul>
				</div>
			</div>
			<div id="heading-custom-panel" class="hidden">
				<input
					type="file"
					name="font_heading_file"
					accept=".ttf,.woff2"
					class="w-full text-sm text-gray-900"
				/>
				{
					theme.customFonts?.heading && (
						<p class="text-xs text-green-600 mt-1">
							Caricato: {theme.customFonts.heading}
							{theme.customFonts.headingType && (
								<span class="ml-1 px-1.5 py-0.5 rounded bg-green-100 text-green-700 font-mono">
									{theme.customFonts.headingType}
								</span>
							)}
						</p>
					)
				}
			</div>
			<!-- Peso -->
			<div class="mt-4">
				<p class="text-xs text-gray-500 mb-1">Peso carattere titoli</p>
				<div class="lg:flex gap-2">
					{
						[
							["300", "Sottile"],
							["400", "Regolare"],
							["700", "Grassetto"],
							["900", "Extra Grassetto"],
						].map(([val, label]) => (
							<label class="flex-1 text-center cursor-pointer">
								<input
									type="radio"
									name="theme_fontWeightHeading"
									value={val}
									checked={
										theme.fontWeightHeading === val ||
										(!theme.fontWeightHeading &&
											val === "700")
									}
									class="sr-only peer"
								/>
								<span class="block py-1.5 px-1 rounded-md border border-gray-200 text-xs text-gray-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 transition">
									{label}
								</span>
							</label>
						))
					}
				</div>
			</div>
			<!-- Interlinea -->
			<div class="mt-4">
				<div class="flex justify-between items-center mb-1">
					<p class="text-xs text-gray-500">Interlinea titoli</p>
					<span
						id="lh-heading-val"
						class="text-xs font-mono text-indigo-600"
						>{theme.lineHeightHeading ?? "1.2"}</span
					>
				</div>
				<input
					type="range"
					name="theme_lineHeightHeading"
					min="1"
					max="2"
					step="0.1"
					value={theme.lineHeightHeading ?? "1.2"}
					class="w-full accent-indigo-500"
					id="lh-heading-range"
				/>
			</div>
		</div>

		<!-- Font Body card -->
		<div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
			<p class="text-sm font-semibold text-gray-700 mb-3">Font Testo</p>
			<div class="flex gap-4 mb-3">
				<label
					class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
				>
					<input
						type="radio"
						name="font_body_mode"
						value="standard"
						checked={!theme.customFonts?.body}
					/>
					Standard
				</label>
				<label
					class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer"
				>
					<input
						type="radio"
						name="font_body_mode"
						value="custom"
						checked={!!theme.customFonts?.body}
					/>
					Custom
				</label>
			</div>
			<div id="body-standard-panel" class="relative">
				<input
					type="hidden"
					name="theme_fontBody"
					id="hidden-font-body"
					value={bodyValue}
				/>
				<button
					type="button"
					id="body-picker-trigger"
					class="w-full flex items-center justify-between gap-2 px-3 py-2 rounded-md border border-gray-200 bg-white text-gray-900 text-sm hover:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-300 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
				>
					<span id="body-picker-label" class="truncate"
						>{bodyLabel}</span
					>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-4 w-4 shrink-0 text-gray-400"
						viewBox="0 0 20 20"
						fill="currentColor"
					>
						<path
							fill-rule="evenodd"
							d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
							clip-rule="evenodd"></path>
					</svg>
				</button>
				<div
					id="body-picker-panel"
					class="hidden absolute z-50 left-0 mt-1 rounded-md border border-gray-200 bg-white shadow-lg"
					style="min-width:220px"
				>
					<div class="p-2 border-b border-gray-100">
						<input
							type="text"
							id="body-picker-search"
							placeholder="Cerca font…"
							autocomplete="off"
							class="w-full px-2 py-1.5 text-sm border border-gray-200 rounded focus:outline-none focus:ring-1 focus:ring-indigo-300"
						/>
					</div>
					<ul
						id="body-picker-list"
						class="overflow-y-auto max-h-52 py-1"
					>
					</ul>
				</div>
			</div>
			<div id="body-custom-panel" class="hidden">
				<input
					type="file"
					name="font_body_file"
					accept=".ttf,.woff2"
					class="w-full text-sm text-gray-900"
				/>
				{
					theme.customFonts?.body && (
						<p class="text-xs text-green-600 mt-1">
							Caricato: {theme.customFonts.body}
							{theme.customFonts.bodyType && (
								<span class="ml-1 px-1.5 py-0.5 rounded bg-green-100 text-green-700 font-mono">
									{theme.customFonts.bodyType}
								</span>
							)}
						</p>
					)
				}
			</div>
			<!-- Peso -->
			<div class="mt-4">
				<p class="text-xs text-gray-500 mb-1">Peso carattere testo</p>
				<div class="lg:flex gap-2">
					{
						[
							["300", "Sottile"],
							["400", "Regolare"],
							["700", "Grassetto"],
							["900", "Extra Grassetto"],
						].map(([val, label]) => (
							<label class="flex-1 text-center cursor-pointer">
								<input
									type="radio"
									name="theme_fontWeightBody"
									value={val}
									checked={
										theme.fontWeightBody === val ||
										(!theme.fontWeightBody && val === "400")
									}
									class="sr-only peer"
								/>
								<span class="block py-1.5 px-1 rounded-md border border-gray-200 text-xs text-gray-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 transition">
									{label}
								</span>
							</label>
						))
					}
				</div>
			</div>
			<!-- Interlinea -->
			<div class="mt-4">
				<div class="flex justify-between items-center mb-1">
					<p class="text-xs text-gray-500">Interlinea testo</p>
					<span
						id="lh-body-val"
						class="text-xs font-mono text-indigo-600"
						>{theme.lineHeightBody ?? "1.6"}</span
					>
				</div>
				<input
					type="range"
					name="theme_lineHeightBody"
					min="1"
					max="2.5"
					step="0.1"
					value={theme.lineHeightBody ?? "1.6"}
					class="w-full accent-indigo-500"
					id="lh-body-range"
				/>
			</div>
		</div>
	</div>

	<!-- Dimensione base font -->
	<div class="mt-4">
		<div class="flex justify-between items-center mb-1">
			<p class="text-sm font-medium text-gray-700">
				Dimensione testo base
			</p>
			<span id="fs-base-val" class="text-xs font-mono text-indigo-600"
				>{theme.fontSizeBase ?? "1rem"}</span
			>
		</div>
		<input
			type="range"
			id="fs-base-range"
			name="theme_fontSizeBase_px"
			min="14"
			max="22"
			step="1"
			value={parseInt(
				(theme.fontSizeBase ?? "16px").replace(/[^0-9]/g, ""),
			) || 16}
			class="w-full accent-indigo-500"
		/>
		<input
			type="hidden"
			name="theme_fontSizeBase"
			id="fs-base-hidden"
			value={theme.fontSizeBase ?? "1rem"}
		/>
		<div class="flex justify-between text-xs text-gray-400 mt-1">
			<span>Piccolo (14px)</span><span>Grande (22px)</span>
		</div>
	</div>

	<!-- Allineamento testo -->
	<div class="mt-4">
		<p class="text-sm font-medium text-gray-700 mb-2">Allineamento testo</p>
		<div class="flex gap-2">
			{
				[
					["left", "← Sinistra"],
					["center", "⊜ Centro"],
					["right", "Destra →"],
				].map(([val, label]) => (
					<label class="flex-1 text-center cursor-pointer">
						<input
							type="radio"
							name="theme_textAlign"
							value={val}
							checked={
								theme.textAlign === val ||
								(!theme.textAlign && val === "left")
							}
							class="sr-only peer"
						/>
						<span class="block py-2 rounded-md border border-gray-200 text-sm text-gray-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 transition">
							{label}
						</span>
					</label>
				))
			}
		</div>
	</div>
</div>

<script>
	// ── GOOGLE FONTS LOADER: inietta <link> per i font visibili ─────────────
	const _loadedGFonts = new Set<string>();

	function loadGoogleFontsBatch(families: string[]) {
		const toLoad = families.filter((f) => !_loadedGFonts.has(f));
		if (toLoad.length === 0) return;
		toLoad.forEach((f) => _loadedGFonts.add(f));
		// Google Fonts CSS2 supporta max ~50 family per richiesta in modo sicuro
		for (let i = 0; i < toLoad.length; i += 50) {
			const chunk = toLoad.slice(i, i + 50);
			const params = chunk
				.map((f) => `family=${encodeURIComponent(f)}`)
				.join("&");
			const link = document.createElement("link");
			link.rel = "stylesheet";
			link.href = `https://fonts.googleapis.com/css2?${params}&display=swap`;
			document.head.appendChild(link);
		}
	}

	// ── FONT PICKER: dropdown custom con ricerca + lazy-load ──────────────────
	function initFontPicker(role: string) {
		const hidden = document.getElementById(
			`hidden-font-${role}`,
		) as HTMLInputElement | null;
		const trigger = document.getElementById(
			`${role}-picker-trigger`,
		) as HTMLButtonElement | null;
		const labelEl = document.getElementById(`${role}-picker-label`);
		const panel = document.getElementById(`${role}-picker-panel`);
		const search = document.getElementById(
			`${role}-picker-search`,
		) as HTMLInputElement | null;
		const list = document.getElementById(`${role}-picker-list`);

		type FontEntry = { v: string; l: string };
		let allFonts: FontEntry[] = [];
		let loaded = false;
		let isOpen = false;
		let current = hidden?.value ?? "";

		async function loadFonts() {
			if (loaded) return;
			try {
				const res = await fetch("/admin/api/fonts.json");
				allFonts = await res.json();
				loaded = true;
			} catch {
				allFonts = [];
			}
		}

		function renderList(query: string) {
			if (!list) return;
			const q = query.toLowerCase().trim();
			const filtered = q
				? allFonts.filter((f) => f.l.toLowerCase().includes(q))
				: allFonts;
			list.innerHTML = "";
			const shown = filtered.slice(0, 100);
			for (const f of shown) {
				const btn = document.createElement("button");
				btn.type = "button";
				// Nome scritto con il font stesso
				btn.style.fontFamily = `'${f.l}', sans-serif`;
				btn.textContent = f.l;
				btn.className = [
					"w-full text-left px-3 py-1.5 text-sm transition-colors",
					f.v === current
						? "bg-indigo-50 text-indigo-700 font-medium"
						: "text-gray-700 hover:bg-gray-50 hover:text-indigo-600",
				].join(" ");
				btn.addEventListener("click", () => pick(f.v, f.l));
				list.appendChild(btn);
			}
			if (shown.length === 0) {
				const empty = document.createElement("li");
				empty.className = "px-3 py-2 text-sm text-gray-400 italic";
				empty.textContent = "Nessun risultato";
				list.appendChild(empty);
			}
			// Carica Google Fonts per i font visibili
			loadGoogleFontsBatch(shown.map((f) => f.l));
		}

		function pick(value: string, label: string) {
			current = value;
			if (hidden) {
				hidden.value = value;
				hidden.dispatchEvent(new Event("input", { bubbles: true }));
			}
			if (labelEl) labelEl.textContent = label;
			closePanel();
		}

		async function openPanel() {
			if (!list) return;
			list.innerHTML =
				'<li class="px-3 py-2 text-sm text-gray-400">Caricamento…</li>';
			panel?.classList.remove("hidden");
			isOpen = true;
			search?.focus();
			await loadFonts();
			renderList(search?.value ?? "");
		}

		function closePanel() {
			panel?.classList.add("hidden");
			isOpen = false;
		}

		trigger?.addEventListener("click", (e) => {
			e.stopPropagation();
			isOpen ? closePanel() : openPanel();
		});
		search?.addEventListener("input", () => renderList(search.value));
		// Blocca il click dentro il panel per non far scattare il listener globale
		panel?.addEventListener("click", (e) => e.stopPropagation());
		document.addEventListener("click", () => {
			if (isOpen) closePanel();
		});
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && isOpen) closePanel();
		});

		return {
			setDisabled(disabled: boolean) {
				if (trigger) trigger.disabled = disabled;
				if (disabled && isOpen) closePanel();
			},
		};
	}

	// ── FONT SELECTOR: toggle Standard / Custom per Heading e Body ────────────
	function initFontSelector(role: string) {
		const picker = initFontPicker(role);
		const standardRadio = document.querySelector<HTMLInputElement>(
			`input[name="font_${role}_mode"][value="standard"]`,
		);
		const customRadio = document.querySelector<HTMLInputElement>(
			`input[name="font_${role}_mode"][value="custom"]`,
		);
		const standardPanel = document.getElementById(`${role}-standard-panel`);
		const customPanel = document.getElementById(`${role}-custom-panel`);

		function applyMode(mode: string) {
			if (mode === "standard") {
				standardPanel?.classList.remove("hidden");
				customPanel?.classList.add("hidden");
				picker.setDisabled(false);
			} else {
				standardPanel?.classList.add("hidden");
				customPanel?.classList.remove("hidden");
				picker.setDisabled(true);
			}
		}

		// Sincronizza con il radio già checked al caricamento
		applyMode(customRadio?.checked ? "custom" : "standard");
		standardRadio?.addEventListener("change", () => applyMode("standard"));
		customRadio?.addEventListener("change", () => applyMode("custom"));
	}

	initFontSelector("heading");
	initFontSelector("body");

	// ── Font Size Base: converte px → rem per l'input nascosto ────────────────
	const fsRange = document.getElementById(
		"fs-base-range",
	) as HTMLInputElement | null;
	const fsHidden = document.getElementById(
		"fs-base-hidden",
	) as HTMLInputElement | null;
	const fsVal = document.getElementById("fs-base-val");

	fsRange?.addEventListener("input", () => {
		const rem = (parseFloat(fsRange.value) / 16)
			.toFixed(4)
			.replace(/\.?0+$/, "");
		const v = `${rem}rem`;
		if (fsHidden) fsHidden.value = v;
		if (fsVal) fsVal.textContent = v;
	});

	// ── Line Height ─────────────────────────────────────────────────────────
	const lhHRange = document.getElementById(
		"lh-heading-range",
	) as HTMLInputElement | null;
	const lhHVal = document.getElementById("lh-heading-val");

	lhHRange?.addEventListener("input", () => {
		if (lhHVal) lhHVal.textContent = lhHRange.value;
	});

	const lhBRange = document.getElementById(
		"lh-body-range",
	) as HTMLInputElement | null;
	const lhBVal = document.getElementById("lh-body-val");

	lhBRange?.addEventListener("input", () => {
		if (lhBVal) lhBVal.textContent = lhBRange.value;
	});
</script>
