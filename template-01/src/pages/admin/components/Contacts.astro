---
export const prerender = false;
const { content } = Astro.props;
---

<section id="contatti" class="tab-section hidden">
	<div class="rounded-xl border border-gray-200 bg-white shadow-sm p-7">
		<h3 class="text-lg font-bold mb-6 text-gray-900">Contatti</h3>
		<form id="form-contatti" class="space-y-6">
			<input
				type="text"
				name="contatti_title"
				value={content.sections.contatti.contatti_title}
				placeholder="Titolo"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<input
				type="text"
				name="contatti_address"
				value={content.sections.contatti.contatti_address}
				placeholder="Indirizzo"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<input
				type="text"
				name="contatti_hours"
				value={content.sections.contatti.contatti_hours}
				placeholder="Orari"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<input
				type="text"
				name="contatti_phone"
				value={content.sections.contatti.contatti_phone}
				placeholder="Telefono"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<input
				type="email"
				name="contatti_email"
				value={content.sections.contatti.contatti_email}
				placeholder="Email"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<input
				type="text"
				name="contatti_googleMapsEmbed"
				value={content.sections.contatti.contatti_googleMapsEmbed}
				placeholder="Google Maps Embed"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			{
				content.sections.contatti.contatti_googleMapsEmbed && (
					<div class="mb-4">
						<iframe
							src={
								content.sections.contatti
									.contatti_googleMapsEmbed
							}
							width="100%"
							height="200"
							style="border:0;"
							allowfullscreen
							loading="lazy"
						/>
					</div>
				)
			}
			<button
				type="submit"
				class="w-full py-2 rounded-md bg-indigo-500 hover:bg-indigo-600 font-semibold text-white transition"
				>Salva</button
			>
		</form>
	</div>
</section>
