---
export const prerender = false;
const { content } = Astro.props;
---

<section id="gallery" class="tab-section hidden">
	<div class="rounded-xl border border-gray-200 bg-white shadow-sm p-7">
		<h3 class="text-lg font-bold mb-6 text-gray-900">Gallery</h3>
		<form id="form-gallery" class="space-y-6">
			<input
				type="text"
				name="gallery_title"
				value={content.sections.gallery.gallery_title}
				placeholder="Titolo"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			{
				Array.isArray(content.sections.gallery.images) &&
					content.sections.gallery.images.length > 0 && (
						<div class="mb-1">
							<p class="text-xs text-gray-400 mb-2">
								Immagini attuali
							</p>
							<div class="flex gap-2 flex-wrap">
								{content.sections.gallery.images.map((img) => (
									<img
										src={img}
										alt="Gallery"
										class="rounded-lg w-20 h-20 object-cover"
										onerror="this.style.display='none'"
									/>
								))}
							</div>
						</div>
					)
			}
			<!-- Nuove immagini: drag & drop con anteprima -->
			<div
				class="dropzone group relative border-2 border-dashed rounded-xl overflow-hidden cursor-pointer transition-colors border-gray-200 hover:border-indigo-400"
				data-dropzone="images"
			>
				<input
					type="file"
					name="gallery_images"
					accept="image/*"
					multiple
					class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
				/>
				<div
					class="dz-empty flex flex-col items-center gap-2 py-8 px-4 text-center"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="w-8 h-8 text-gray-400"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="1.5"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
						></path>
					</svg>
					<p class="text-sm text-gray-500">
						Trascina immagini o <span
							class="font-medium text-indigo-600">sfoglia</span>
					</p>
					<p class="text-xs text-gray-400">
						Puoi selezionarne più d'una
					</p>
				</div>
				<div class="dz-filled hidden px-4 pb-4 pt-3">
					<p class="text-xs text-gray-500 mb-2">
						Nuove immagini · clicca per cambiare
					</p>
					<div class="dz-previews flex flex-wrap gap-2"></div>
				</div>
			</div>
			<button type="submit" class="hidden">Salva</button>
		</form>
	</div>
</section>
