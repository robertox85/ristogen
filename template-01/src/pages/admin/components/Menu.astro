---
const { content } = Astro.props;
---

<section id="menu" class="tab-section hidden">
	<div class="rounded-xl border border-gray-200 bg-white shadow-sm p-7">
		<h3 class="text-lg font-bold mb-6 text-gray-900">Menu</h3>
		<form id="form-menu" class="space-y-6">
			{
				content.sections.menu.menu_pdfLink && (
					<a
						href={content.sections.menu.menu_pdfLink}
						target="_blank"
						rel="noopener"
						class="block mb-4 text-indigo-600 underline"
					>
						PDF attuale
					</a>
				)
			}
			<!-- PDF: drag & drop con nome file -->
			<div
				class="dropzone group relative border-2 border-dashed rounded-xl overflow-hidden cursor-pointer transition-colors border-gray-200 hover:border-indigo-400"
				data-dropzone="file"
			>
				<input
					type="file"
					name="menu_pdfLink"
					accept="application/pdf"
					class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
				/>
				<div
					class="dz-empty flex flex-col items-center gap-2 py-6 px-4 text-center"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="w-8 h-8 text-gray-400"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="1.5"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
						></path>
					</svg>
					<p class="text-sm text-gray-500">
						Trascina il PDF o <span
							class="font-medium text-indigo-600">sfoglia</span
						>
					</p>
				</div>
				<div class="dz-filled hidden items-center gap-3 px-4 py-4">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="w-5 h-5 text-red-500 shrink-0"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="1.5"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
						></path>
					</svg>
					<div class="min-w-0">
						<p
							class="dz-filename text-sm text-gray-800 font-medium truncate"
						>
						</p>
						<p class="dz-filesize text-xs text-gray-400"></p>
					</div>
				</div>
			</div>
			<button type="submit" class="hidden">Salva</button>
		</form>
	</div>
</section>
