---
export const prerender = false;

---

<aside
	id="sidebar"
	class="w-52 shrink-0 bg-white border-r border-gray-200 flex flex-col transition-[width] duration-200 ease-in-out overflow-hidden"
>
	<!-- Header sidebar: logo + toggle sempre visibili -->
	<div
		id="sidebar-header"
		class="flex items-center justify-between h-14 px-3 border-b border-gray-100 shrink-0"
	>
		<!-- Brand: nascosto quando collassata -->
		<div
			id="sidebar-brand"
			class="flex items-center gap-2 min-w-0 flex-1 overflow-hidden mr-2"
		>
			<div
				class="w-7 h-7 rounded-lg bg-indigo-600 flex items-center justify-center shrink-0"
			>
				<svg
					width="14"
					height="14"
					viewBox="0 0 24 24"
					fill="none"
					stroke="white"
					stroke-width="2.5"
					stroke-linecap="round"
					stroke-linejoin="round"
					><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
					></path><polyline points="9 22 9 12 15 12 15 22"
					></polyline></svg
				>
			</div>
			<span
				class="text-sm font-bold text-gray-900 whitespace-nowrap overflow-hidden"
				>Ristogen</span
			>
		</div>
		<!-- Toggle: sempre visibile -->
		<button
			id="btn-sidebar-toggle"
			title="Comprimi/espandi"
			class="shrink-0 w-7 h-7 flex items-center justify-center rounded-md text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
		>
			<svg
				id="sidebar-toggle-icon"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2.5"
				stroke-linecap="round"
				stroke-linejoin="round"
				style="transition:transform 0.2s"
				><polyline points="15 18 9 12 15 6"></polyline></svg
			>
		</button>
	</div>

	<!-- Nav items -->
	<nav
		class="flex flex-col gap-0.5 p-2 flex-1 overflow-y-auto overflow-x-hidden"
	>
		{
			[
				{
					tab: "theme",
					icon: "M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z",
					label: "Theme",
				},
				{
					tab: "hero",
					icon: "M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z",
					label: "Hero",
				},
				{
					tab: "about",
					icon: "M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z",
					label: "About",
				},
				{
					tab: "gallery",
					icon: "M4 16l4.586-4.586a2 2 0 0 1 2.828 0L16 16m-2-2 1.586-1.586a2 2 0 0 1 2.828 0L20 14m-6-6h.01M6 20h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z",
					label: "Gallery",
				},
				{
					tab: "menu",
					icon: "M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2",
					label: "Menu",
				},
				{
					tab: "contatti",
					icon: "M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z",
					label: "Contatti",
				},
				{
					tab: "footer",
					icon: "M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1zM4 22v-7",
					label: "Footer",
				},
			].map(({ tab, icon, label }) => (
				<button
					class="tab-btn w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 hover:bg-indigo-50 hover:text-indigo-700 transition-colors"
					data-tab={tab}
					title={label}
				>
					<svg
						class="shrink-0"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d={icon} />
					</svg>
					<span class="sidebar-label whitespace-nowrap">{label}</span>
				</button>
			))
		}
	</nav>
</aside>

<script>
	// ── SIDEBAR TOGGLE ──────────────────────────────────────────────────────────
	const sidebar = document.getElementById("sidebar") as HTMLElement | null;
	const sidebarHeader = document.getElementById("sidebar-header");
	const sidebarBrand = document.getElementById("sidebar-brand");
	const toggleIcon = document.getElementById(
		"sidebar-toggle-icon",
	) as HTMLElement | null;
	const sidebarLabels =
		document.querySelectorAll<HTMLElement>(".sidebar-label");

	let sidebarOpen = true;

	function setSidebar(open: boolean) {
		sidebarOpen = open;
		if (!sidebar) return;
		sidebar.style.cssText = "";

		const navBtns = Array.from(
			document.querySelectorAll<HTMLElement>(".tab-btn"),
		);

		if (open) {
			sidebar.classList.replace("w-14", "w-52");
			sidebarHeader?.classList.replace(
				"justify-center",
				"justify-between",
			);
			sidebarBrand?.classList.remove("hidden");
			sidebarLabels.forEach((el) => el.classList.remove("hidden"));
			navBtns.forEach((btn) => {
				btn.classList.remove("justify-center");
				btn.classList.add("gap-3");
			});
			if (toggleIcon) toggleIcon.style.transform = "rotate(0deg)";
		} else {
			sidebar.classList.replace("w-52", "w-14");
			sidebarHeader?.classList.replace(
				"justify-between",
				"justify-center",
			);
			sidebarBrand?.classList.add("hidden");
			sidebarLabels.forEach((el) => el.classList.add("hidden"));
			navBtns.forEach((btn) => {
				btn.classList.add("justify-center");
				btn.classList.remove("gap-3");
			});
			if (toggleIcon) toggleIcon.style.transform = "rotate(180deg)";
		}

		// Notifica ad altri componenti lo stato aggiornato
		document.dispatchEvent(
			new CustomEvent("admin:sidebarChanged", { detail: { open } }),
		);
	}

	document
		.getElementById("btn-sidebar-toggle")
		?.addEventListener("click", () => setSidebar(!sidebarOpen));

	// Riceve richieste da altri componenti (es. PreviewPanel → chiudi per fare spazio)
	document.addEventListener("admin:setSidebar", (e: Event) => {
		setSidebar((e as CustomEvent<{ open: boolean }>).detail.open);
	});

	// Collassa automaticamente su schermi piccoli
	if (window.innerWidth < 768) setSidebar(false);
</script>
