---
const { content } = Astro.props;
---

<section id="about" class="tab-section hidden">
	<div class="rounded-xl border border-gray-200 bg-white shadow-sm p-7">
		<h3 class="text-lg font-bold mb-6 text-gray-900">About</h3>
		<form id="form-about" class="space-y-6">
			{
				content.sections.about.about_image && (
					<img
						src={content.sections.about.about_image}
						alt="Preview About"
						class="mb-4 rounded-lg w-full max-w-xs text-gray-900"
						onerror="this.style.display='none'"
					/>
				)
			}
			<input
				type="file"
				name="about_image"
				accept="image/*"
				class="w-full text-gray-900"
			/>
			<input
				type="text"
				name="about_preTitle"
				value={content.sections.about.about_preTitle}
				placeholder="Pre-titolo"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<!-- <textarea
									name="about_text"
									rows="5"
									placeholder="Testo"
									class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
									>{
										content.sections.about.about_text
									}</textarea
								> -->

			<div>
				<label class="block mb-2 text-sm font-medium text-gray-700"
					>Testo</label
				>
				<div
					id="editor-about"
					class="h-40 bg-white border border-gray-200 rounded-md text-gray-900"
				>
					{content.sections.about.about_text}
				</div>
				<input
					type="hidden"
					name="about_text"
					value={content.sections.about.about_text}
				/>
			</div>

			<button
				type="submit"
				class="w-full py-2 rounded-md bg-indigo-500 hover:bg-indigo-600 font-semibold text-white transition"
				>Salva</button
			>
		</form>
	</div>
</section>
