---
export const prerender = false;
const { content } = Astro.props;
---

<section id="about" class="tab-section hidden">
	<div class="rounded-xl border border-gray-200 bg-white shadow-sm p-7">
		<h3 class="text-lg font-bold mb-6 text-gray-900">About</h3>
		<form id="form-about" class="space-y-6">
			<!-- Immagine about: drag & drop con anteprima -->
			<div
				class="dropzone group relative border-2 border-dashed rounded-xl overflow-hidden cursor-pointer transition-colors border-gray-200 hover:border-indigo-400"
				data-dropzone="image"
			>
				<input
					type="file"
					name="about_image"
					accept="image/*"
					class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
				/>
				<div
					class:list={[
						"dz-empty flex flex-col items-center gap-2 py-8 px-4 text-center",
						{ hidden: content.sections.about.about_image },
					]}
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="w-8 h-8 text-gray-400"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="1.5"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"
						></path>
					</svg>
					<p class="text-sm text-gray-500">
						Trascina un'immagine o <span
							class="font-medium text-indigo-600">sfoglia</span
						>
					</p>
					<p class="text-xs text-gray-400">PNG · JPG · WebP</p>
				</div>
				<div
					class:list={[
						"dz-filled relative",
						{ hidden: !content.sections.about.about_image },
					]}
				>
					<img
						class="dz-thumb w-full max-h-52 object-cover"
						src={content.sections.about.about_image || ""}
						alt="Anteprima immagine"
					/>
					<div
						class="absolute inset-0 flex items-center justify-center bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"
					>
						<span class="text-white text-sm font-semibold"
							>Cambia immagine</span
						>
					</div>
				</div>
			</div>
			<input
				type="text"
				name="about_preTitle"
				value={content.sections.about.about_preTitle}
				placeholder="Pre-titolo"
				class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
			/>
			<!-- <textarea
									name="about_text"
									rows="5"
									placeholder="Testo"
									class="w-full px-3 py-2 rounded-md border border-gray-200 bg-gray-50 text-gray-900"
									>{
										content.sections.about.about_text
									}</textarea
								> -->

			<div>
				<label class="block mb-2 text-sm font-medium text-gray-700"
					>Testo</label
				>
				<div
					id="editor-about"
					class="h-40 bg-white border border-gray-200 rounded-md text-gray-900"
				>
					{content.sections.about.about_text}
				</div>
				<input
					type="hidden"
					name="about_text"
					value={content.sections.about.about_text}
				/>
			</div>

			<button type="submit" class="hidden">Salva</button>
		</form>
	</div>
</section>

<script>
	// ── QUILL RICH TEXT EDITOR ────────────────────────────────────────────────
	// Mantiene l'input nascosto sincronizzato ad ogni modifica,
	// evitando race condition con il listener submit generico in index.astro.
	document.addEventListener("DOMContentLoaded", () => {
		const aboutInput = document.querySelector<HTMLInputElement>(
			'input[name="about_text"]',
		);
		const quill = new Quill("#editor-about", { theme: "snow" });
		(window as any).__quillAbout = quill;

		if (aboutInput?.value) {
			quill.root.innerHTML = aboutInput.value;
		}

		quill.on("text-change", () => {
			if (aboutInput) aboutInput.value = quill.root.innerHTML;
		});
	});
</script>
