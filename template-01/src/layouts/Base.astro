---
import type { ClientContent } from "../schema/content.schema";
import Analytics from "../components/Analytics.astro";

declare const __ENABLED_LANGS__: string[];

interface Props {
	content: ClientContent;
}
const { content } = Astro.props;
const { theme } = content;
const enabledLangs = __ENABLED_LANGS__;
---

<!doctype html>
<html>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title></title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link
			href={`https://fonts.googleapis.com/css2?family=${theme.fontHeading}:wght@400;700&family=${theme.fontBody}:wght@400;500&display=swap`}
			rel="stylesheet"
		/>

		<style
			is:global
			define:vars={{
				"color-primary": theme.primary,
				"color-secondary": theme.secondary,
				"color-bg": theme.bg,
				"color-text": theme.text,
				"font-heading": theme.fontHeading,
				"font-body": theme.fontBody,
				"radius-base": theme.radius,
			}}
		>
			:root {
				--color-primary: var(--color-primary);
				--color-secondary: var(--color-secondary);
				--color-bg: var(--color-bg);
				--color-text: var(--color-text);
				--font-heading: var(--font-heading);
				--font-body: var(--font-body);
				--radius-base: var(--radius-base);
				--spacing-section: 8rem;
			}
			body {
				background: var(--color-bg);
				color: var(--color-text);
				font-family: var(--font-body);
			}
			h1,
			h2,
			h3,
			h4 {
				font-family: var(--font-heading);
			}
			.card,
			.rounded-xl {
				border-radius: var(--radius-base);
			}
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>
