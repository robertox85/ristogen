---
import type { ClientContent } from "../schema/content.schema";
import Analytics from "../components/Analytics.astro";

declare const __ENABLED_LANGS__: string[];

interface Props {
	content: ClientContent;
}
const { content } = Astro.props;
const { theme } = content;
const enabledLangs = __ENABLED_LANGS__;

const hasCustomHeading = !!theme.customFonts?.heading;
const hasCustomBody = !!theme.customFonts?.body;

// Estrae il nome del font da un valore CSS (es. "'Playfair Display', serif" → "Playfair Display")
const extractFontName = (cssValue: string) =>
	cssValue.replace(/'/g, "").split(",")[0].trim();

// Costruisce la query Google Fonts solo per i ruoli senza font custom
const gFontParts: string[] = [];
if (!hasCustomHeading)
	gFontParts.push(
		`family=${extractFontName(theme.fontHeading)}:wght@400;700`,
	);
if (!hasCustomBody)
	gFontParts.push(`family=${extractFontName(theme.fontBody)}:wght@400;500`);
const googleFontsHref =
	gFontParts.length > 0
		? `https://fonts.googleapis.com/css2?${gFontParts.join("&")}&display=swap`
		: null;

// Valori finali delle variabili CSS font (usa il tipo rilevato come fallback)
const headingFallback = theme.customFonts?.headingType || "serif";
const bodyFallback = theme.customFonts?.bodyType || "sans-serif";
const cssFontHeading = hasCustomHeading
	? `'CustomHeading', ${headingFallback}`
	: theme.fontHeading;
const cssFontBody = hasCustomBody
	? `'CustomBody', ${bodyFallback}`
	: theme.fontBody;
---

<!doctype html>
<html>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title></title>

		{
			googleFontsHref && (
				<>
					<link
						rel="preconnect"
						href="https://fonts.googleapis.com"
					/>
					<link href={googleFontsHref} rel="stylesheet" />
				</>
			)
		}

		{
			hasCustomHeading && (
				<style
					set:html={`@font-face { font-family: 'CustomHeading'; src: url('${theme.customFonts!.heading}') format('woff2'); font-display: swap; }`}
				/>
			)
		}
		{
			hasCustomBody && (
				<style
					set:html={`@font-face { font-family: 'CustomBody'; src: url('${theme.customFonts!.body}') format('woff2'); font-display: swap; }`}
				/>
			)
		}

		<style
			is:global
			define:vars={{
				"color-primary": theme.primary,
				"color-secondary": theme.secondary,
				"color-bg": theme.bg,
				"color-text": theme.text,
				"font-heading": cssFontHeading,
				"font-body": cssFontBody,
				"font-weight-heading": theme.fontWeightHeading ?? "700",
				"font-weight-body": theme.fontWeightBody ?? "400",
				"font-size-base": theme.fontSizeBase ?? "1rem",
				"line-height-heading": theme.lineHeightHeading ?? "1.2",
				"line-height-body": theme.lineHeightBody ?? "1.6",
				"text-align-base": theme.textAlign ?? "left",
				"radius-base": theme.radius,
				"section-padding": theme.sectionPadding ?? "6rem",
				"spacing-base": theme.spacing ?? "1.5rem",
				"fs-h1": theme.fsH1 ?? "4rem",
				"fs-h2": theme.fsH2 ?? "2.5rem",
				"fs-h3": theme.fsH3 ?? "1.75rem",
				"mobile-scale-h1": (
					parseFloat(theme.mobileScaleH1 ?? "65") / 100
				).toFixed(2),
				"mobile-scale-h2": (
					parseFloat(theme.mobileScaleH2 ?? "80") / 100
				).toFixed(2),
				"ls-h1": theme.letterSpacingH1 ?? "0em",
				"ls-h2": theme.letterSpacingH2 ?? "0em",
			}}
		>
			:root {
				--color-primary: var(--color-primary);
				--color-secondary: var(--color-secondary);
				--color-bg: var(--color-bg);
				--color-text: var(--color-text);
				--font-heading: var(--font-heading);
				--font-body: var(--font-body);
				--font-weight-heading: var(--font-weight-heading);
				--font-weight-body: var(--font-weight-body);
				--font-size-base: var(--font-size-base);
				--line-height-heading: var(--line-height-heading);
				--line-height-body: var(--line-height-body);
				--text-align-base: var(--text-align-base);
				--radius-base: var(--radius-base);
				--section-padding: var(--section-padding);
				--spacing-base: var(--spacing-base);
				--spacing-section: var(--section-padding);
				--fs-h1: var(--fs-h1);
				--fs-h2: var(--fs-h2);
				--fs-h3: var(--fs-h3);
				--mobile-scale-h1: var(--mobile-scale-h1);
				--mobile-scale-h2: var(--mobile-scale-h2);
				--ls-h1: var(--ls-h1);
				--ls-h2: var(--ls-h2);
			}
			body {
				background: var(--color-bg);
				color: var(--color-text);
				font-family: var(--font-body);
				font-size: var(--font-size-base);
				font-weight: var(--font-weight-body);
				line-height: var(--line-height-body);
				text-align: var(--text-align-base);
			}
			h1,
			h2,
			h3,
			h4 {
				font-family: var(--font-heading);
				font-weight: var(--font-weight-heading);
				line-height: var(--line-height-heading);
			}
			h1 {
				font-size: var(--fs-h1);
				letter-spacing: var(--ls-h1);
			}
			h2 {
				font-size: var(--fs-h2);
				letter-spacing: var(--ls-h2);
			}
			h3,
			h4 {
				font-size: var(--fs-h3);
			}
			@media (max-width: 768px) {
				h1 {
					font-size: calc(var(--fs-h1) * var(--mobile-scale-h1));
				}
				h2 {
					font-size: calc(var(--fs-h2) * var(--mobile-scale-h2));
				}
			}
			.card,
			.rounded-xl {
				border-radius: var(--radius-base);
			}
			section {
				padding-top: var(--section-padding);
				padding-bottom: var(--section-padding);
			}
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>
