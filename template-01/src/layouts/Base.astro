---
import type { ClientContent } from "../schema/content.schema";
import Analytics from "../components/Analytics.astro";

declare const __ENABLED_LANGS__: string[];

interface Props {
	content: ClientContent;
}
const { content } = Astro.props;
const { theme } = content;
const enabledLangs = __ENABLED_LANGS__;

const hasCustomHeading = !!theme.customFonts?.heading;
const hasCustomBody = !!theme.customFonts?.body;

// Estrae il nome del font da un valore CSS (es. "'Playfair Display', serif" → "Playfair Display")
const extractFontName = (cssValue: string) =>
	cssValue.replace(/'/g, "").split(",")[0].trim();

// Costruisce la query Google Fonts solo per i ruoli senza font custom
const gFontParts: string[] = [];
if (!hasCustomHeading)
	gFontParts.push(
		`family=${extractFontName(theme.fontHeading)}:wght@400;700`,
	);
if (!hasCustomBody)
	gFontParts.push(`family=${extractFontName(theme.fontBody)}:wght@400;500`);
const googleFontsHref =
	gFontParts.length > 0
		? `https://fonts.googleapis.com/css2?${gFontParts.join("&")}&display=swap`
		: null;

// Valori finali delle variabili CSS font (usa il tipo rilevato come fallback)
const headingFallback = theme.customFonts?.headingType || "serif";
const bodyFallback = theme.customFonts?.bodyType || "sans-serif";
const cssFontHeading = hasCustomHeading
	? `'CustomHeading', ${headingFallback}`
	: theme.fontHeading;
const cssFontBody = hasCustomBody
	? `'CustomBody', ${bodyFallback}`
	: theme.fontBody;
---

<!doctype html>
<html>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title></title>

		{
			googleFontsHref && (
				<>
					<link
						rel="preconnect"
						href="https://fonts.googleapis.com"
					/>
					<link href={googleFontsHref} rel="stylesheet" />
				</>
			)
		}

		{
			hasCustomHeading && (
				<style
					set:html={`@font-face { font-family: 'CustomHeading'; src: url('${theme.customFonts!.heading}') format('woff2'); font-display: swap; }`}
				/>
			)
		}
		{
			hasCustomBody && (
				<style
					set:html={`@font-face { font-family: 'CustomBody'; src: url('${theme.customFonts!.body}') format('woff2'); font-display: swap; }`}
				/>
			)
		}

		<style
			is:global
			define:vars={{
				"init-color-primary": theme.primary,
				"init-color-secondary": theme.secondary,
				"init-color-bg": theme.bg,
				"init-color-text": theme.text,
				"init-font-heading": cssFontHeading,
				"init-font-body": cssFontBody,
				"init-font-weight-heading": theme.fontWeightHeading ?? "700",
				"init-font-weight-body": theme.fontWeightBody ?? "400",
				"init-font-size-base": theme.fontSizeBase ?? "1rem",
				"init-line-height-heading": theme.lineHeightHeading ?? "1.2",
				"init-line-height-body": theme.lineHeightBody ?? "1.6",
				"init-text-align-base": theme.textAlign ?? "left",
				"init-radius-base": theme.radius,
				"init-section-padding": theme.sectionPadding ?? "6rem",
				"init-spacing-base": theme.spacing ?? "1.5rem",
				"init-fs-h1": theme.fsH1 ?? "4rem",
				"init-fs-h2": theme.fsH2 ?? "2.5rem",
				"init-fs-h3": theme.fsH3 ?? "1.75rem",
				"init-mobile-scale-h1": (
					parseFloat(theme.mobileScaleH1 ?? "65") / 100
				).toFixed(2),
				"init-mobile-scale-h2": (
					parseFloat(theme.mobileScaleH2 ?? "80") / 100
				).toFixed(2),
				"init-ls-h1": theme.letterSpacingH1 ?? "0em",
				"init-ls-h2": theme.letterSpacingH2 ?? "0em",
			}}
		>
			:root {
				--color-primary: var(--init-color-primary);
				--color-secondary: var(--init-color-secondary);
				--color-bg: var(--init-color-bg);
				--color-text: var(--init-color-text);
				--font-heading: var(--init-font-heading);
				--font-body: var(--init-font-body);
				--font-weight-heading: var(--init-font-weight-heading);
				--font-weight-body: var(--init-font-weight-body);
				--font-size-base: var(--init-font-size-base);
				--line-height-heading: var(--init-line-height-heading);
				--line-height-body: var(--init-line-height-body);
				--text-align-base: var(--init-text-align-base);
				--radius-base: var(--init-radius-base);
				--section-padding: var(--init-section-padding);
				--spacing-base: var(--init-spacing-base);
				--spacing-section: var(--section-padding);
				--fs-h1: var(--init-fs-h1);
				--fs-h2: var(--init-fs-h2);
				--fs-h3: var(--init-fs-h3);
				--mobile-scale-h1: var(--init-mobile-scale-h1);
				--mobile-scale-h2: var(--init-mobile-scale-h2);
				--ls-h1: var(--init-ls-h1);
				--ls-h2: var(--init-ls-h2);
			}
			body {
				background: var(--color-bg);
				color: var(--color-text);
				font-family: var(--font-body);
				font-size: var(--font-size-base);
				font-weight: var(--font-weight-body);
				line-height: var(--line-height-body);
				text-align: var(--text-align-base);
			}
			h1,
			h2,
			h3,
			h4 {
				font-family: var(--font-heading);
				font-weight: var(--font-weight-heading);
				line-height: var(--line-height-heading);
			}
			h1 {
				font-size: var(--fs-h1);
				letter-spacing: var(--ls-h1);
			}
			h2 {
				font-size: var(--fs-h2);
				letter-spacing: var(--ls-h2);
			}
			h3,
			h4 {
				font-size: var(--fs-h3);
			}
			@media (max-width: 768px) {
				h1 {
					font-size: calc(var(--fs-h1) * var(--mobile-scale-h1));
				}
				h2 {
					font-size: calc(var(--fs-h2) * var(--mobile-scale-h2));
				}
			}
			.card,
			.rounded-xl {
				border-radius: var(--radius-base);
			}
			section {
				padding-top: var(--section-padding);
				padding-bottom: var(--section-padding);
			}
		</style>
		<!-- Live preview: riceve CSS var injections via postMessage dall'admin dashboard -->
		<script>
			window.addEventListener("message", (e) => {
				if (e.origin !== window.location.origin) return;
				const data = e.data;
				if (!data || typeof data !== "object") return;
				if (data.type === "setVar") {
					document.documentElement.style.setProperty(
						data.name,
						data.value,
					);
				} else if (data.type === "loadFont") {
					const fontName = String(data.fontFamily)
						.replace(/'/g, "")
						.split(",")[0]
						.trim();
					if (
						document.head.querySelector(
							`link[data-gf="${fontName}"]`,
						)
					)
						return;
					const link = document.createElement("link");
					link.rel = "stylesheet";
					link.href = `https://fonts.googleapis.com/css2?family=${encodeURIComponent(fontName).replace(/%20/g, "+")}:ital,wght@0,400;0,700;1,400&display=swap`;
					(
						link as HTMLLinkElement & { dataset: DOMStringMap }
					).dataset.gf = fontName;
					document.head.appendChild(link);
				}
			});

			// ── ADMIN EDIT MODE: attivo solo quando l'iframe è dentro la preview admin ──
			if (window.parent !== window) {
				// Inietta CSS hover per gli elementi editabili
				const s = document.createElement("style");
				s.textContent =
					"[data-editable]{cursor:pointer!important;transition:outline .15s}" +
					"[data-editable]:hover{outline:2px solid #6366f1!important;outline-offset:3px!important}";
				document.head.appendChild(s);

				// Intercetta click (capture phase) prima di link/tel/mailto
				document.addEventListener(
					"click",
					(e) => {
						const el = (e.target as Element)?.closest(
							"[data-editable]",
						);
						if (!el) return;
						e.preventDefault();
						e.stopPropagation();
						window.parent.postMessage(
							{
								type: "editField",
								field: el.getAttribute("data-editable"),
							},
							window.location.origin,
						);
					},
					true,
				);
			}
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>
