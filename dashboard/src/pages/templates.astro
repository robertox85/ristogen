---
import DashboardLayout from "../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Ristogen — Templates">
	<div class="mx-auto flex max-w-495 w-full flex-col gap-6 px-5 py-8">
		<div
			class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm"
		>
			<div class="border-b border-gray-200 p-4">
				<h2
					class="text-[15px] font-semibold tracking-tight text-gray-900"
				>
					Gestione Template
				</h2>
			</div>
			<div
				class="flex flex-col items-center justify-center gap-3 px-5 py-16 text-center text-gray-400"
			>
				<span class="text-4xl">🎨</span>
				<p class="text-sm font-medium">Sezione in arrivo</p>
				<p class="max-w-xs text-xs leading-relaxed">
					Qui potrai gestire i template disponibili per le landing
					page dei tuoi clienti.
				</p>
			</div>
		</div>
	</div>
</DashboardLayout>
