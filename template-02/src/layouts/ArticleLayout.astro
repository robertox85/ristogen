---
import { marked } from "marked";
import Analytics from "../components/Analytics.astro";
import type { ClientContent, Article } from "../schema/content.schema";

interface Props {
	content: ClientContent;
	article: Article;
	lang: "it" | "en";
}

const { content, article, lang } = Astro.props;
const { site, theme } = content;

const bodyHtml = marked(article.body);
const itPath = `${site.meta.canonical}/it/articoli/${article.slug}`;
const enPath = `${site.meta.canonical}/en/articles/${article.slug}`;
const canonical = lang === "it" ? itPath : enPath;
const altLang = lang === "it" ? "en" : "it";
const altCanonical = lang === "it" ? enPath : itPath;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{article.title} — {site.schema_org.name}</title>
		<meta name="description" content={article.description} />
		<link rel="canonical" href={canonical} />
		{article.noindex && <meta name="robots" content="noindex" />}
		<meta property="og:title" content={article.title} />
		<meta property="og:description" content={article.description} />
		{
			article.og_image && (
				<meta property="og:image" content={article.og_image} />
			)
		}
		<meta property="og:type" content="article" />
		<link rel="alternate" hreflang={altLang} href={altCanonical} />
		<link rel="alternate" hreflang={lang} href={canonical} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:wght@400;500;600;700;800;900&display=swap"
			rel="stylesheet"
		/>
		<link
			href={`https://fonts.googleapis.com/css2?family=${theme.fonts.heading}:wght@400;700&family=${theme.fonts.body}:wght@400;500&display=swap`}
			rel="stylesheet"
		/>
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "Article",
				headline: article.title,
				description: article.description,
				datePublished: article.date,
				author: { "@type": "Organization", name: site.schema_org.name },
				publisher: {
					"@type": "Organization",
					name: site.schema_org.name,
				},
			})}
		/>
		<Analytics analytics={site.analytics} />
	</head>
	<body
		class="antialiased bg-neutral-950 text-white"
		style={`
  --font-heading: '${theme.fonts.heading}', 'Playfair Display', serif;
  --font-body: '${theme.fonts.body}', 'Inter', sans-serif;
`}
	>
		<article class="max-w-3xl mx-auto px-4 py-16 md:py-24">
			<header class="mb-10">
				<p class="text-sm text-neutral-500 mb-2">{article.date}</p>
				<h1
					class="text-4xl md:text-5xl font-bold font-heading text-white leading-tight mb-4"
				>
					{article.title}
				</h1>
				<p class="text-lg text-neutral-400">{article.description}</p>
			</header>
			<div
				class="prose prose-invert prose-lg max-w-none text-neutral-300 leading-relaxed"
				set:html={bodyHtml}
			/>
			<footer class="mt-12 pt-6 border-t border-neutral-800">
				<a
					href={lang === "it" ? "/" : "/en/"}
					class="text-rose-500 hover:text-rose-400 transition font-medium"
				>
					← {lang === "it" ? "Torna alla home" : "Back to home"}
				</a>
			</footer>
		</article>

		<script
			is:inline
			src="https://identity.netlify.com/v1/netlify-identity-widget.js"
		></script>
		<script is:inline>
			if (window.netlifyIdentity) {
				window.netlifyIdentity.on("init", (user) => {
					if (!user) {
						window.netlifyIdentity.on("login", () => {
							document.location.href = "/admin/";
						});
					}
				});
			}
		</script>
	</body>
</html>
