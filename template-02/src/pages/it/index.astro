---
import Base from "../../layouts/Base.astro";
import Hero from "../../components/Hero.astro";
import About from "../../components/About.astro";
import Menu from "../../components/Menu.astro";
import Gallery from "../../components/Gallery.astro";
import Contatti from "../../components/Contatti.astro";
import Footer from "../../components/Footer.astro";
import { getContent } from "../../content";

const content = getContent("it");
---

<Base {content}>
	<Hero sections={content.sections} site={content.site} lang="it" />
	<About sections={content.sections} />
	<Gallery sections={content.sections} />
	<Menu sections={content.sections} lang="it" />
	<Contatti sections={content.sections} />
	<Footer site={content.site} contatti={content.sections.contatti} />
</Base>
