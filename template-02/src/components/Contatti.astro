---
import type { ClientContent } from "../schema/content.schema";

interface Props {
	sections: ClientContent["sections"];
}
const { contatti } = Astro.props.sections;
---

{
	contatti.enabled && (
		<section id="contact" class="py-24 md:py-32 bg-neutral-950">
			<div class="container px-4 mx-auto">
				<div class="text-center mb-16">
					<p class="mb-4 text-rose-500 font-semibold uppercase tracking-widest">
						Contatti
					</p>
					<h2 class="text-4xl md:text-5xl font-bold font-heading text-white tracking-px-n leading-tight">
						Vieni a trovarci
					</h2>
				</div>
				<div class="flex flex-wrap -m-8">
					<div class="w-full lg:w-1/2 p-8">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
							{contatti.indirizzo && (
								<div class="p-6 border border-neutral-800 rounded-2xl">
									<div class="mb-4">
										<svg
											xmlns="http://www.w3.org/2000/svg"
											class="w-8 h-8 text-rose-500"
											viewBox="0 0 24 24"
											fill="none"
										>
											<path
												d="M17.657 16.657L13.414 20.9C13.039 21.275 12.53 21.485 12 21.485C11.47 21.485 10.961 21.275 10.586 20.9L6.343 16.657C3.219 13.533 3.219 8.467 6.343 5.343C9.467 2.219 14.533 2.219 17.657 5.343C20.781 8.467 20.781 13.533 17.657 16.657Z"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
											<path
												d="M12 11C13.1046 11 14 10.1046 14 9C14 7.89543 13.1046 7 12 7C10.8954 7 10 7.89543 10 9C10 10.1046 10.8954 11 12 11Z"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
										</svg>
									</div>
									<h4 class="mb-2 text-lg font-bold text-white">
										Indirizzo
									</h4>
									<p class="text-neutral-400">
										{contatti.indirizzo}
									</p>
								</div>
							)}
							{contatti.orari && (
								<div class="p-6 border border-neutral-800 rounded-2xl">
									<div class="mb-4">
										<svg
											xmlns="http://www.w3.org/2000/svg"
											class="w-8 h-8 text-rose-500"
											viewBox="0 0 24 24"
											fill="none"
										>
											<path
												d="M12 8V12L15 15"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
											<circle
												cx="12"
												cy="12"
												r="9"
												stroke="currentColor"
												stroke-width="2"
											/>
										</svg>
									</div>
									<h4 class="mb-2 text-lg font-bold text-white">
										Orari
									</h4>
									<p class="text-neutral-400">
										{contatti.orari}
									</p>
								</div>
							)}
							{contatti.telefono && (
								<div class="p-6 border border-neutral-800 rounded-2xl">
									<div class="mb-4">
										<svg
											xmlns="http://www.w3.org/2000/svg"
											class="w-8 h-8 text-rose-500"
											viewBox="0 0 24 24"
											fill="none"
										>
											<path
												d="M3 5C3 3.89543 3.89543 3 5 3H8.27924C8.70967 3 9.09181 3.27543 9.22792 3.68377L10.7257 8.17721C10.8831 8.64932 10.6694 9.16531 10.2243 9.38787L7.96701 10.5165C9.06925 12.9612 11.0388 14.9308 13.4835 16.033L14.6121 13.7757C14.8347 13.3306 15.3507 13.1169 15.8228 13.2743L20.3162 14.7721C20.7246 14.9082 21 15.2903 21 15.7208V19C21 20.1046 20.1046 21 19 21H18C9.71573 21 3 14.2843 3 6V5Z"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
										</svg>
									</div>
									<h4 class="mb-2 text-lg font-bold text-white">
										Telefono
									</h4>
									<p class="text-neutral-400">
										<a
											href={`tel:${contatti.telefono}`}
											class="hover:text-rose-500 transition"
										>
											{contatti.telefono}
										</a>
									</p>
								</div>
							)}
							{contatti.email && (
								<div class="p-6 border border-neutral-800 rounded-2xl">
									<div class="mb-4">
										<svg
											xmlns="http://www.w3.org/2000/svg"
											class="w-8 h-8 text-rose-500"
											viewBox="0 0 24 24"
											fill="none"
										>
											<path
												d="M3 8L10.89 13.26C11.2187 13.4793 11.6049 13.5963 12 13.5963C12.3951 13.5963 12.7813 13.4793 13.11 13.26L21 8M5 19H19C20.1046 19 21 18.1046 21 17V7C21 5.89543 20.1046 5 19 5H5C3.89543 5 3 5.89543 3 7V17C3 18.1046 3.89543 19 5 19Z"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
										</svg>
									</div>
									<h4 class="mb-2 text-lg font-bold text-white">
										Email
									</h4>
									<p class="text-neutral-400">
										<a
											href={`mailto:${contatti.email}`}
											class="hover:text-rose-500 transition"
										>
											{contatti.email}
										</a>
									</p>
								</div>
							)}
						</div>
					</div>
					<div class="w-full lg:w-1/2 p-8">
						{contatti.google_maps_url ? (
							<div class="w-full h-80 lg:h-full min-h-80 rounded-2xl overflow-hidden">
								<iframe
									src={contatti.google_maps_url}
									class="w-full h-full border-0"
									allowfullscreen
									loading="lazy"
									referrerpolicy="no-referrer-when-downgrade"
									title="Google Maps"
								/>
							</div>
						) : (
							<div class="w-full h-80 lg:h-full min-h-80 bg-neutral-800 rounded-2xl flex items-center justify-center">
								<p class="text-neutral-500">
									Mappa non disponibile
								</p>
							</div>
						)}
					</div>
				</div>
				{(contatti.social?.instagram || contatti.social?.facebook) && (
					<div class="mt-12 text-center">
						<div class="flex justify-center gap-6">
							{contatti.social.instagram && (
								<a
									href={contatti.social.instagram}
									target="_blank"
									rel="noopener"
									class="text-neutral-400 hover:text-rose-500 transition"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="w-6 h-6"
										fill="currentColor"
										viewBox="0 0 24 24"
									>
										<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
									</svg>
								</a>
							)}
							{contatti.social.facebook && (
								<a
									href={contatti.social.facebook}
									target="_blank"
									rel="noopener"
									class="text-neutral-400 hover:text-rose-500 transition"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="w-6 h-6"
										fill="currentColor"
										viewBox="0 0 24 24"
									>
										<path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z" />
									</svg>
								</a>
							)}
						</div>
					</div>
				)}
			</div>
		</section>
	)
}
