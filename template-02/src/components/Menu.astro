---
import type { ClientContent } from "../schema/content.schema";

interface Props {
	sections: ClientContent["sections"];
	lang?: "it" | "en";
	preview?: boolean;
}
const { menu } = Astro.props.sections;
const lang = Astro.props.lang ?? "it";
const preview = Astro.props.preview ?? true;
const PREVIEW_LIMIT = 4;
const categories = preview
	? menu.categories.slice(0, PREVIEW_LIMIT)
	: menu.categories;
const menuPath = lang === "en" ? "/en/menu" : "/it/menu";

const ALLERGENI: Record<number, string> = {
	1: "Glutine",
	2: "Crostacei",
	3: "Uova",
	4: "Pesce",
	5: "Arachidi",
	6: "Soia",
	7: "Latte",
	8: "Frutta a guscio",
	9: "Sedano",
	10: "Senape",
	11: "Sesamo",
	12: "Anidride solforosa",
	13: "Lupini",
	14: "Molluschi",
};
---

<section id="menu" class="py-24 md:py-32 bg-neutral-950">
	<div class="container px-4 mx-auto">
		<div class="text-center mb-16">
			<p
				class="mb-4 text-rose-500 font-semibold uppercase tracking-widest"
			>
				{lang === "en" ? "Our Menu" : "Il nostro Menù"}
			</p>
			<h2
				class="text-4xl md:text-5xl font-bold font-heading text-white tracking-px-n leading-tight"
			>
				{lang === "en" ? "Signature Creations" : "Le nostre specialità"}
			</h2>
		</div>
		{
			categories.map((cat) => (
				<div class="mb-16">
					<h3 class="mb-8 text-2xl font-bold font-heading text-rose-500">
						{cat.name}
					</h3>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						{cat.items.map((item) => (
							<div class="p-6 border border-neutral-800 rounded-2xl">
								{item.image && (
									<img
										src={item.image}
										alt={item.image_alt ?? item.name}
										class="w-full h-48 object-cover rounded-xl mb-4"
										loading="lazy"
									/>
								)}
								<div class="flex justify-between items-start mb-3">
									<div class="flex items-center gap-2 flex-wrap">
										<h4 class="text-xl font-bold text-white">
											{item.name}
										</h4>
										{item.badge && (
											<span class="text-xs bg-rose-600 text-white px-2 py-0.5 rounded-full font-semibold">
												{item.badge}
											</span>
										)}
									</div>
									<span class="text-rose-500 font-bold ml-4 whitespace-nowrap">
										€ {item.price}
									</span>
								</div>
								<p class="text-neutral-400">
									{item.description}
								</p>
								{item.allergeni &&
									item.allergeni.length > 0 && (
										<p class="text-xs text-neutral-600 italic mt-2">
											Allergeni:{" "}
											{item.allergeni
												.map(
													(id) => ALLERGENI[id] ?? id,
												)
												.join(", ")}
										</p>
									)}
							</div>
						))}
					</div>
				</div>
			))
		}
		{
			preview && (
				<div class="text-center mt-8">
					<a
						href={menuPath}
						class="inline-block py-3 px-8 text-white font-semibold border border-rose-600 rounded-xl focus:ring focus:ring-rose-300 bg-rose-600 hover:bg-rose-700 transition ease-in-out duration-200"
					>
						{lang === "en"
							? "View full menu →"
							: "Vedi menù completo →"}
					</a>
				</div>
			)
		}
	</div>
</section>
