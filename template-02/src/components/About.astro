---
import type { ClientContent } from "../schema/content.schema";

interface Props {
	sections: ClientContent["sections"];
}
const { about } = Astro.props.sections;
---

{
	about.enabled && (
		<section id="about" class="py-24 md:py-32 bg-neutral-950">
			<div class="container px-4 mx-auto">
				<div class="flex flex-wrap items-center -m-8">
					<div class="w-full md:w-1/2 p-8">
						<p class="mb-4 text-rose-500 font-semibold uppercase tracking-widest">
							{about.title
								? about.title.split(" ").slice(0, 2).join(" ")
								: "Our Story"}
						</p>
						<h2 class="mb-6 text-4xl md:text-5xl font-bold font-heading text-white tracking-px-n leading-tight">
							{about.title}
						</h2>
						<p class="text-lg text-neutral-400 leading-relaxed">
							{about.text}
						</p>
					</div>
					{about.image && (
						<div class="w-full md:w-1/2 p-8">
							<img
								class="w-full rounded-2xl"
								src={about.image}
								alt={about.image_alt ?? ""}
							/>
						</div>
					)}
				</div>
			</div>
		</section>
	)
}
